<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <template id="student_attendance_detailed_report">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <br></br>
                        <br></br>
                        <br></br>
                        <div class="text-center">
                            <h3>
                                <strong>Detailed Student Attendance Report</strong>
                            </h3>
                        </div>
                        <br></br>
                        <div class="row mt24">
                            <div style="width:50%; margin-left:15px;">
                                <b>Student Name:</b>
                                <span t-esc="get_student_name"/>
                            </div>
                            <div style="width:50%; margin-left:15px;">
                                <b>From Date:</b>
                                <span t-esc="from_date" t-options="{'widget':'date'}"/>
                                <b>To Date:</b>
                                <span t-esc="to_date" t-options="{'widget':'date'}"/>
                            </div>
                        </div>
                        <br/>
                        <table class="table table-bordered">
                            <thead class="text-center"
                                   style="background-color:#eeeeee; font-size:14px; font-weight:600;">
                                <th class="text-center">Date</th>
                                <th class="text-center">Course</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Remark</th>
                                <th class="text-center">Mark</th>
                                <th class="text-center">Behavior</th>
                            </thead>
                            <tbody class="text-center" style="font-size:12px;">
                                <t t-foreach="get_detailed_data" t-as="attendance">
                                    <tr>
                                        <td class="text-center">
                                            <span t-esc="attendance['date']" t-options="{'widget':'date'}"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="attendance['course']"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="attendance['status']"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="attendance['remark']"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="attendance['mark']"/>
                                        </td>
                                        <td class="text-center">
                                            <span t-esc="attendance['behavior']"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td class="text-center" colspan="4">
                                        <b>Total Sessions</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_total_sessions"/>
                                        </b>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center" colspan="4">
                                        <b>Present</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_present_count"/>
                                        </b>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center" colspan="4">
                                        <b>Absent</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_absent_count"/>
                                        </b>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center" colspan="4">
                                        <b>Late</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_late_count"/>
                                        </b>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center" colspan="4">
                                        <b>Attendance Rate</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_attendance_rate"/>%
                                        </b>
                                    </td>
                                </tr>
                                <tr t-if="get_grade_count &gt; 0">
                                    <td class="text-center" colspan="4">
                                        <b>Average Grade</b>
                                    </td>
                                    <td class="text-center" colspan="2">
                                        <b>
                                            <span t-esc="get_average_grade"/>
                                        </b>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>
</odoo>