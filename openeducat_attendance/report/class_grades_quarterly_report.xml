<?xml version="1.0" encoding="UTF-8"?>
<odoo>
        <template id="class_grades_quarterly_report">
            <t t-set="data_report_landscape" t-value="True"/>
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">      
                        <br></br>
                        <div class="text-center">
                            <h3>
                                <strong>Сводный отчет по итоговым оценкам класса</strong>
                            </h3>
                        </div>                        
                        <div class="row mt24">
                            <div style="width:50%; margin-left:15px;">
                                <b>Класс:</b>
                                <span t-esc="get_batch_name"/>
                            </div>
                        </div>
                        <br/>
                        <table class="table table-bordered">
                            <thead class="text-center"
                                   style="background-color:#eeeeee; font-size:14px; font-weight:600;">
                                <th class="text-center">Ученик</th>
                                <th class="text-center" t-foreach="get_subjects_list" t-as="subject">
                                    <span t-esc="subject"/>
                                </th>
                                <th class="text-center">Средняя итоговая оценка</th>
                            </thead>
                            <tbody class="text-center" style="font-size:14px;">
                                <t t-foreach="get_quarterly_grades" t-as="student_data">
                                    <tr>
                                        <td class="text-center">
                                            <span t-esc="student_data['student_name']"/>
                                        </td>
                                        <td class="text-center" t-foreach="get_subjects_list" t-as="subject">
                                            <span t-esc="student_data['subjects'][subject]"/>
                                        </td>
                                        <!-- Calculate average quarterly grade for the student -->
                                        <t t-set="student_grades" t-value="[]"/>
                                        <t t-foreach="get_subjects_list" t-as="subject">
                                            <t t-set="grade" t-value="student_data['subjects'][subject]"/>
                                            <t t-if="grade and grade.isdigit()">
                                                <t t-set="student_grades" t-value="student_grades + [int(grade)]"/>
                                            </t>
                                        </t>
                                        <td class="text-center">
                                            <t t-if="student_grades">
                                                <t t-set="avg_grade" t-value="round(sum(student_grades) / len(student_grades), 2)"/>
                                                <span t-esc="avg_grade"/>
                                            </t>
                                            <t t-else="">
                                                <span>0.0</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td class="text-center">
                                        <b>Средний балл класса</b>
                                    </td>
                                    <td class="text-center" t-foreach="get_subjects_list" t-as="subject">
                                        <!-- Empty cells for subject columns -->
                                    </td>
                                    <td class="text-center">
                                        <b>
                                            <span t-esc="get_class_overall_average"/>
                                        </b>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>
</odoo>