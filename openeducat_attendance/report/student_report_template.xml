<odoo>
    <!-- 1. Действие для печати (Report Action) -->
    <record id="action_student_summary_report" model="ir.actions.report">
        <field name="name">Итоговые оценки</field>
        <field name="model">student.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">openeducat_attendance.student_summary_report_template</field>
        <field name="report_file">openeducat_attendance.student_summary_report_template</field>
        <field name="print_report_name">
            'Итоговые оценки %s %s%s' % (
                object.academic_year_id.name, 
                object.batch_id.name if object.batch_id else 'вся школа',
                ' ' + object.student_ids[0].name.split()[0] if object.student_ids else ''
            )
        </field>
    </record>

    <!-- 2. Шаблон (Дизайн) -->
    <template id="student_summary_report_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    .page, h2, h3, h4, h5, table, div, span {
                        font-family: "Times New Roman", Times, serif !important;
                        color: black !important;
                    }

                    .report-title {
                        text-align: center;                        
                        font-weight: bold !important;
                        margin-bottom: 10pt !important;
                    }

                    /* Стиль заголовка класса для навигации PDF */
                    .batch-header {
                        <!-- page-break-before: always; /* Каждый класс с новой страницы */ -->
                        border-bottom: 2pt solid black;
                        margin-bottom: 15pt;
                        padding-bottom: 5pt;
                    }

                    .student-block {
                        page-break-inside: avoid !important; 
                        display: block;
                        width: 100%;
                        margin-bottom: 10pt !important;
                        position: relative;
                    }
                    
                    .student-info {
                        font-size: 14pt !important;
                        font-weight: bold !important;
                        margin-bottom: 8pt !important;
                    }

                    .diary-table {
                        width: 100%;
                        border-collapse: collapse !important;
                        table-layout: fixed;
                    }

                    .diary-table th, .diary-table td {
                        border: 0.5pt solid black !important;
                        padding: 4pt 6pt !important;
                        vertical-align: middle !important;
                        font-size: 12pt !important;
                    }

                    .diary-table tbody tr:nth-child(even) {
                        background-color: #f9f9f9 !important;
                    }

                    .diary-table td.col-year-cell {
                        font-weight: bold !important;
                    }

                    .col-no { width: 30pt; text-align: center; }
                    .col-subj { width: auto; text-align: left; }
                    .col-q { width: 70pt; text-align: center; }
                    .col-year { width: 50pt; text-align: center; font-weight: bold !important; }

                    .diary-table thead th {
                        background-color: #f2f2f2 !important;
                        font-size: 11pt !important;
                        font-weight: bold !important;
                        text-align: center !important;
                    }

                    .text-center { text-align: center !important; }

                    .cut-line {
                        /* Дополнительная страховка: не начинать новую страницу с линии разрыва */
                        page-break-before: avoid !important;
                        width: 100%;
                        border-top: 1pt dashed #666 !important;
                        margin-top: 5pt !important;
                        margin-bottom: 20pt !important;
                        position: relative;
                    }

                    .cut-line:after {
                        content: "✂";
                        position: absolute;
                        top: -12pt;
                        left: 20pt;
                        font-size: 16pt;
                        background: white;
                        padding: 0 4pt;
                    }

                    .attendance-row { background-color: #ffffff !important; }
                    .attendance-row td { font-size: 10pt !important; color: #444 !important; }
                    .attendance-row .att-icon-cell { text-align: center !important; width: 30pt; }
                </style>

                <div class="page">
                    <h2 class="report-title">Итоговые оценки за <t t-out="year" /> уч.год</h2>

                    <!-- ГЛАВНЫЙ ЦИКЛ: ПО КЛАССАМ -->
                    <t t-foreach="grouped_data" t-as="group">

                        <!-- ДОБАВЛЯЕМ РАЗРЫВ СТРАНИЦЫ ПЕРЕД КАЖДЫМ КЛАССОМ, КРОМЕ ПЕРВОГО -->
                        <t t-if="not group_first">
                            <p style="page-break-before: always;"></p>
                        </t>
                        
                        <!-- Заголовок класса (попадёт в навигацию PDF) -->
                        <div class="batch-header">
                            <h3 style="margin: 0; font-weight: bold;">
                                Класс: <t t-out="group['batch_name']"/>
                            </h3>
                        </div>

                        <!-- ВЛОЖЕННЫЙ ЦИКЛ: ПО УЧЕНИКАМ -->
                        <t t-foreach="group['students']" t-as="res">
                            <div class="student-block">
                                <h4 class="student-info">
                                    <t t-out="res['student']" />, <t t-out="group['batch_name']" /> класс
                                </h4>

                                <table class="diary-table">
                                    <thead>
                                        <tr>
                                            <th class="col-no">№</th>
                                            <th class="col-subj">Предметы</th>
                                            <th class="col-q">1 четверть</th>
                                            <th class="col-q">2 четверть</th>
                                            <th class="col-q">3 четверть</th>
                                            <th class="col-q">4 четверть</th>
                                            <th class="col-year">За год</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="idx" t-value="1" />
                                        <t t-foreach="res['subjects']" t-as="sub">
                                            <tr>
                                                <td class="text-center"><t t-out="idx" /></td>
                                                <td><t t-out="sub['name']" /></td>
                                                <t t-foreach="sub['grades']" t-as="grade">
                                                    <td class="text-center"><t t-out="grade" /></td>
                                                </t>
                                                <td class="text-center col-year-cell"><t t-out="sub['year_grade']" /></td>
                                            </tr>
                                            <t t-set="idx" t-value="idx + 1" />
                                        </t>

                                        <!-- Посещаемость -->
                                        <tr class="attendance-row" style="border-top: 1pt solid black !important;">
                                            <td class="att-icon-cell"><i class="fa fa-calendar-times-o" /></td>
                                            <td class="att-label">Пропущено уроков всего</td>
                                            <t t-foreach="res['attendance']" t-as="att">
                                                <td class="text-center"><t t-out="att['total_missed']" /></td>
                                            </t>
                                            <td class="text-center col-year-cell"><t t-out="res['year_total']['missed']" /></td>
                                        </tr>

                                        <tr class="attendance-row">
                                            <td class="att-icon-cell"><i class="fa fa-medkit" /></td>
                                            <td class="att-label">В т.ч. по болезни</td>
                                            <t t-foreach="res['attendance']" t-as="att">
                                                <td class="text-center"><t t-out="att['sick']" /></td>
                                            </t>
                                            <td class="text-center col-year-cell"><t t-out="res['year_total']['sick']" /></td>
                                        </tr>

                                        <tr class="attendance-row">
                                            <td class="att-icon-cell"><i class="fa fa-clock-o" /></td>
                                            <td class="att-label">Опозданий</td>
                                            <t t-foreach="res['attendance']" t-as="att">
                                                <td class="text-center"><t t-out="att['late']" /></td>
                                            </t>
                                            <td class="text-center col-year-cell"><t t-out="res['year_total']['late']" /></td>
                                        </tr>
                                    </tbody>
                                </table>

                                <!-- Линия отреза  -->
                                <t >
                                    <div class="cut-line"></div>
                                </t>

                            </div>                            
                        </t>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>