<odoo>
    <!-- 1. Действие для печати (Report Action) -->
    <record id="action_student_summary_report" model="ir.actions.report">
        <field name="name">Итоговые оценки</field>
        <field name="model">student.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">openeducat_attendance.student_summary_report_template</field>
        <field name="report_file">openeducat_attendance.student_summary_report_template</field>
        <field name="print_report_name">'Ведомость - %s' % object.batch_id.name</field>        
    </record>

    <!-- 2. Шаблон (Дизайн) -->
    <template id="student_summary_report_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    /* Принудительный шрифт для всей страницы и всех заголовков */
                    .page, h2, h3, h4, h5, table, div, span {
                        font-family: "Times New Roman", Times, serif !important;
                        color: black !important;
                    }

                    /* Главный заголовок документа */
                    .report-title {
                        text-align: center;
                        font-size: 22pt !important;
                        font-weight: bold !important;
                        margin-bottom: 20pt !important;
                    }

                    /* Блок ученика */
                    .student-block {
                        /* Это заставит блок (вместе с линией внутри) всегда переноситься целиком */
                        page-break-inside: avoid !important; 
                        display: block;
                        width: 100%;
                        margin-bottom: 20pt !important;
                    }
                    
                    /* Имя ученика */
                    .student-info {
                        font-size: 14pt !important;
                        font-weight: bold !important;
                        margin-bottom: 8pt !important;
                    }

                    /* Сетка таблицы */
                    .diary-table {
                        width: 100%;
                        border-collapse: collapse !important;
                        vertical-align: middle !important;
                        table-layout: fixed; /* Фиксируем ширину, чтобы колонки не прыгали */
                    }

                    .diary-table th, .diary-table td {
                        border: 0.5pt solid black !important; /* Тонкая четкая линия */
                        padding: 1pt 6pt !important;
                        vertical-align: middle !important;
                        font-weight: normal !important;
                        font-size: 14pt !important;

                        /* Добавляем жесткое ограничение высоты строки текста */
                        line-height: 1.4 !important;
                    }

                    /* Настройка ширины колонок */
                    .col-no { width: 30pt; text-align: center; }
                    .col-subj { width: auto; text-align: left; } /* Предмет заберет остаток места */
                    .col-q { width: 70pt; text-align: center; }  /* Узкие колонки для четвертей */
                    .col-year { width: 50pt; text-align: center; font-weight: bold !important; }

                    /* Заголовки таблицы */
                    .diary-table thead th {
                        background-color: #f2f2f2 !important;
                        font-size: 12pt !important;
                        font-weight: bold !important;
                        text-align: center !important;
                    }

                    .text-center { text-align: center !important; }

                    /* Линия отреза */
                    .cut-line {
                        width: 100%;
                        border-top: 1pt dashed #666 !important;
                        margin-top: 5pt !important;
                        margin-bottom: 25pt !important;
                        position: relative;
                        height: 0;
                        /* Чтобы линия не оставалась одна внизу страницы */
                        page-break-after: avoid !important;
                    }

                    .cut-line:after {
                        content: "✂";
                        position: absolute;
                        top: -13pt;
                        left: 20pt;
                        font-size: 20pt;
                        background: white;
                        padding: 0 4pt;
                        color: #000;
                    }
                </style>

                <div class="page">
                    <!-- Заголовок пишется один раз -->
                    <h4 class="report-title">ИТОГОВЫЕ ОЦЕНКИ</h4>

                    <t t-foreach="student_data" t-as="res">                        
                        <!-- Линия появится перед каждым ВТОРЫМ учеником (индексы 1, 3, 5...) -->                        
                        <t t-if="res_index % 2 == 1">
                            <div class="cut-line"></div>
                        </t>

                        <div class="student-block">
                            <!-- Сведения об ученике -->
                            <h4 class="student-info">
                                <t t-out="res['student']"/>, <t t-out="res['batch']"/> класс, <t t-out="res['year']"/> уч. год
                            </h4>

                            <table class="diary-table">
                                <thead>
                                    <tr>
                                        <th class="col-no">№</th>
                                        <th class="col-subj">Предметы</th>
                                        <th class="col-q">1 четверть</th>
                                        <th class="col-q">2 четверть</th>
                                        <th class="col-q">3 четверть</th>
                                        <th class="col-q">4 четверть</th>
                                        <th class="col-year">За год</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-set="idx" t-value="1"/>
                                    <t t-foreach="res['subjects']" t-as="sub">
                                        <tr>
                                            <td class="text-center"><t t-out="idx"/></td>
                                            <td><t t-out="sub['name']"/></td>
                                            <t t-foreach="sub['grades']" t-as="grade">
                                                <td class="text-center"><t t-out="grade"/></td>
                                            </t>
                                            <td class="text-center" style="font-weight: bold !important;">
                                                <t t-out="sub['year_grade']"/>
                                            </td>
                                        </tr>
                                        <t t-set="idx" t-value="idx + 1"/>
                                    </t>
                                    
                                    <!-- Посещаемость -->
                                    <tr style="border-top: 1pt solid black !important;">
                                        <td colspan="2">Пропущено уроков всего</td>
                                        <t t-foreach="res['attendance']" t-as="att">
                                            <td class="text-center"><t t-out="att['total_missed']"/></td>
                                        </t>
                                        <td class="text-center" style="font-weight: bold !important;">
                                            <t t-out="res['year_total']['missed']"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2">В т.ч. по болезни</td>
                                        <t t-foreach="res['attendance']" t-as="att">
                                            <td class="text-center"><t t-out="att['sick']"/></td>
                                        </t>
                                        <td class="text-center" style="font-weight: bold !important;">
                                            <t t-out="res['year_total']['sick']"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="2">Опозданий</td>                                        
                                        <t t-foreach="res['attendance']" t-as="att">
                                            <td class="text-center"><t t-out="att['late']"/></td>
                                        </t>                                        
                                        <td class="text-center" style="font-weight: bold !important;">
                                            <t t-out="res['year_total']['late']"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>                                                
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>