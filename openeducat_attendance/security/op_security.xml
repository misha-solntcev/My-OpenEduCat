<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.module.category" id="module_category_all_op_attendance">
            <field name="name">Attendance</field>
            <field name="description">Helps you manage your institutes different-different users.</field>
            <field name="sequence">106</field>
            <field name="parent_id" eval="False"/>
        </record>
        <record id="module_category_openeducat_attendance" model="ir.module.category">
            <field name="name">Attendance</field>
            <field name="parent_id" ref="openeducat_attendance.module_category_all_op_attendance"/>
            <field name="sequence">17</field>
        </record>

        <record id="group_op_attendance_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_openeducat_attendance"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_op_attendance_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_openeducat_attendance"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('openeducat_attendance.group_op_attendance_user'))]"/>
        </record>

        <record model="ir.rule" id="student_attendance_line_rule">
            <field name="name">Student Attendance Line Rule</field>
            <field name="model_id" ref="model_op_attendance_line"/>
            <field name="groups" eval="[(4, ref('__custom__.group_op_students'))]"/>
            <field name="domain_force">[('student_id.user_id','=',user.id)]</field>
        </record>
        
        <record model="ir.rule" id="faculty_attendance_line_rule">
            <field name="name">Faculty Attendance Line Rule</field>
            <field name="model_id" ref="model_op_attendance_line"/>
            <field name="groups" eval="[(4, ref('__custom__.group_op_faculty'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record model="ir.rule" id="manager_attendance_line_rule">
            <field name="name">Manager Attendance Line Rule</field>
            <field name="model_id" ref="model_op_attendance_line"/>
            <field name="groups"
                   eval="[(4, ref('openeducat_attendance.group_op_attendance_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_faculty_attendance_line" model="ir.rule">
            <field name="name">User Attendance</field>
            <field name="model_id" ref="model_op_attendance_line"/>
            <field name="groups" eval="[(4, ref('openeducat_attendance.group_op_attendance_user'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record model="ir.rule" id="attendance_type_multi_comp_rule">
            <field name="name">attendance type multi comp rule</field>
            <field name="model_id" ref="openeducat_attendance.model_op_attendance_type"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', '|', ('company_id','=',False), ('company_id','child_of',[user.company_id.id]), ('company_id','in',user.company_ids.ids)]</field>
        </record>
        
        <!-- Добавляем правило доступа для студентов к модели op.subject.grades -->
        <record model="ir.rule" id="student_subject_grades_rule">
            <field name="name">Student Subject Grades Rule</field>
            <field name="model_id" ref="model_op_subject_grades"/>
            <field name="groups" eval="[(4, ref('__custom__.group_op_students'))]"/>
            <field name="domain_force">[('student_id.user_id','=',user.id)]</field>
        </record>
        
        <!-- Изменяем правило доступа для преподавателей к модели op.subject.grades -->
        <record model="ir.rule" id="faculty_subject_grades_rule">
            <field name="name">Faculty Subject Grades Rule</field>
            <field name="model_id" ref="model_op_subject_grades"/>
            <field name="groups" eval="[(4, ref('__custom__.group_op_faculty'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_student_see_own_subject_grades" model="ir.rule">
            <field name="name">Student can see only own subject grades</field>
            <field name="model_id" ref="model_op_subject_grades"/>
            <field name="groups" eval="[(4, ref('__custom__.group_op_students'))]"/>
            <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        </record>
        
</odoo>
