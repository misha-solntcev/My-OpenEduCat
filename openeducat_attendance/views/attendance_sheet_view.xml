<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 1. СПИСОК -->
    <record id="view_op_attendance_sheet_tree" model="ir.ui.view">
        <field name="name">op.attendance.sheet.list</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <!-- Раскрашиваем всю строку в зависимости от статуса -->
            <list string="Журналы уроков" 
                default_order="start_datetime asc, batch_id"
                sample="1"
                expand="0"
                decoration-info="state == 'confirm'"
                decoration-warning="state == 'start'"
                decoration-success="state == 'done'"
                decoration-muted="state == 'cancel'">

                <field name="attendance_date" string="Дата"
                    widget="date" readonly="1" optional="show" />
                <field name="faculty_id" string="Учитель"
                    widget="many2one_avatar_user" optional="show" />
                <field name="batch_id" string="Класс"
                    decoration-bf="1" optional="show" />
                <field name="subject_id" string="Предмет"
                    decoration-bf="1" optional="show" />
                <field name="lesson_topic" string="Тема занятия"
                    optional="hide" />


                <field name="total_present" string="👥 Явка"
                    decoration-success="total_present > 0"
                    decoration-bf="1" />
                <field name="total_absent" string="❌ Неявка"
                    decoration-danger="total_absent > 0"
                    decoration-bf="1" />

                <!-- Статус в виде цветного бейджа -->
                <field name="state" widget="badge"
                    decoration-info="state == 'confirm'"
                    decoration-warning="state == 'start'"
                    decoration-success="state == 'done'"
                    decoration-danger="state == 'cancel'" />

                <!-- Техническое поле для техподдержки, скрыто -->
                <field name="name" string="ID" optional="hide" />
            </list>
        </field>
    </record>

    <!-- 2. ФОРМА -->
    <record id="view_op_attendance_sheet_form" model="ir.ui.view">
        <field name="name">op.attendance.sheet.form</field>
        <field name="model">op.attendance.sheet</field>
        <field name="priority" eval="8" />
        <field name="arch" type="xml">
            <form string="Attendance Sheet">

                <header>
                    <!-- 1. Начать урок (Синхронно переводит и Урок в 'start') -->
                    <button name="action_attendance_start" type="object" string="Начать урок"
                        invisible="state != 'confirm'" class="btn-primary o_attendance_start_btn" icon="fa-play" />
                    <!-- 2. Завершить урок (Синхронно переводит и Урок в 'done' + расчет оценок) -->
                    <button name="action_attendance_done" type="object" string="Завершить урок"
                        invisible="state != 'start'" class="btn-primary o_attendance_done_btn" icon="fa-check-circle" />
                    <!-- 3. Редактировать (Возврат из Проведен в Идет урок для правок) -->
                    <button name="action_attendance_edit" type="object" string="Редактировать"
                        invisible="state != 'done'" icon="fa-edit" class="btn-secondary" />
                    <!-- 4. Восстановить (из Отменен в Черновик) -->
                    <button name="action_attendance_confirm" type="object" string="Восстановить"
                        invisible="state != 'cancel'" icon="fa-undo" />
                    <!-- 5. Отменить (только если еще нет оценок - проверка в Python) -->
                    <button name="action_attendance_cancel" type="object" string="Отменить"
                        invisible="state not in ('draft', 'start')" icon="fa-times" />
                    <!-- Статус-бар -->
                    <field name="state" widget="statusbar" statusbar_visible="confirm,start,done" />
                </header>

                <sheet>
                    

                    <!-- КОНТЕКСТНАЯ СПРАВКА -->
                    <div class="alert alert-info text-center" role="alert" invisible="state != 'confirm'">
                        <i class="fa fa-info-circle me-2"/>
                        Урок запланирован. Список учеников будет создан автоматически при нажатии <strong>"Начать урок"</strong>.
                    </div>
                    <div class="alert alert-warning text-center" role="alert" invisible="state != 'start' or total_present > 0">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        Пожалуйста, отметьте посещаемость (кнопка <strong>"Присутствуют"</strong>), иначе в статистике останутся пустые области.
                    </div>



                    <!-- 1. ИНДИКАТОРЫ И СТАТИСТИКА (Верхний правый угол) -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-users" title="Присутствие" disabled="1">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="total_present"/> / <field name="total_students"/>
                                </span>
                                <span class="o_stat_text">Присутствует</span>
                            </div>
                        </button>
                    </div>

                    <!-- Индикатор архивации/отмены -->
                    <widget name="web_ribbon" title="Отменен" bg_color="text-bg-danger" invisible="active"/>

                    <!-- 2. HERO HEADER (ГЛАВНАЯ ПАНЕЛЬ) -->
                    <div class="d-flex flex-column flex-md-row align-items-stretch gap-3 mb-4 mt-2">
                        
                        <!-- ЛЕВАЯ КОЛОНКА: Обложка учебника -->
                        <div class="d-flex align-items-center justify-content-center bg-white border rounded-3 shadow-sm p-2" 
                            style="width: 110px; height: 145px; flex-shrink: 0; margin: 0 auto;">
                            <field name="textbook_image" widget="image" class="w-100 h-100 object-fit-contain" options="{'zoom': true}"/>
                        </div>

                        <!-- ЦЕНТРАЛЬНАЯ КОЛОНКА: Основные данные -->
                        <div class="flex-grow-1 d-flex flex-column justify-content-center text-center text-md-start">
                            <!-- Верхняя строка: Класс и Дата -->
                            <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-2 mb-2">
                                <span class="badge rounded-pill fw-bold px-3 py-1" style="background: #eef2ff; color: #4f46e5; border: 1px solid #e0e7ff;">
                                    <field name="batch_id" readonly="1"/>
                                </span>
                                <span class="text-muted small fw-medium">
                                    <i class="fa fa-calendar-o me-1" title="Дата"/> <field name="attendance_date" readonly="1"/>
                                </span>
                            </div>

                            <!-- Название предмета (Крупно) -->
                            <h1 class="fw-bolder mb-3" style="letter-spacing: -0.5px; color: #1e293b; font-size: 2.2rem;">
                                <field name="subject_id" readonly="1"/>
                            </h1>

                            <!-- Детали урока: Время, Кабинет, Четверть -->
                            <div class="d-flex flex-wrap justify-content-center justify-content-md-start gap-3 text-muted small">
                                <div class="d-flex align-items-center bg-white px-2 py-1 rounded border shadow-sm">
                                    <i class="fa fa-clock-o me-2 text-primary" title="Время"/>
                                    <field name="timing" class="fw-bold text-dark"/>
                                </div>
                                <div class="d-flex align-items-center bg-white px-2 py-1 rounded border shadow-sm">
                                    <i class="fa fa-map-marker me-2 text-danger" title="Кабинет"/>
                                    <field name="classroom_id" class="fw-bold text-dark" options="{'no_open': True}"/>
                                </div>
                                <div class="d-flex align-items-center bg-white px-2 py-1 rounded border shadow-sm">
                                    <i class="fa fa-graduation-cap me-2 text-success" title="Четверть"/>
                                    <field name="term_id" readonly="1" options="{'no_open': True}" class="fw-bold text-dark"/>
                                </div>
                            </div>
                        </div>
                        
                        <!-- ПРАВАЯ КОЛОНКА: Квадратная карточка учителя -->                                                
                        <div class="ms-md-auto d-flex align-items-center p-3 border rounded bg-white shadow-sm" style="min-height: 65px;">
                            <field name="faculty_id" 
                                widget="many2one_avatar" 
                                readonly="1" 
                                options="{'no_open': True}" 
                                class="fs-1 fw-bold text-dark"/>
                        </div>
                    </div>

                    <!-- 3. АКЦЕНТНЫЙ БЛОК: ТЕМА ЗАНЯТИЯ -->
                    <div class="p-4 mb-4 rounded-3 border-start border-4 border-primary bg-white shadow-sm position-relative overflow-hidden" style="background: linear-gradient(to right, #ffffff, #f8fafc);">
                        <!-- Фоновая иконка для красоты -->
                        <i class="fa fa-pencil-square-o position-absolute" title="Тема занятия" style="right: -10px; bottom: -10px; font-size: 100px; opacity: 0.03; transform: rotate(-15deg);"/>
                        
                        <label for="lesson_topic" class="fw-bold text-uppercase mb-2 text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">
                            <i class="fa fa-edit me-1 text-primary" title="Тема занятия"/> Тема текущего занятия
                        </label>
                        <div class="h2 mb-0">
                            <field name="lesson_topic" 
                                placeholder="Например: Решение квадратных уравнений через дискриминант..." 
                                class="w-100 border-0 p-0 fw-bold shadow-none text-dark" 
                                style="background: transparent; outline: none;"
                                readonly="state == 'done'"/>
                        </div>
                    </div>

                    <!-- Скрытые поля для системной логики -->
                    <div invisible="1">
                        <field name="session_id" readonly="1" force_save="1"/>
                        <field name="register_id" readonly="1" force_save="1"/>
                        <field name="display_title"/>
                    </div>

                    <notebook>
                        <page string="Ученики и Оценки" name="marks">


                            <!-- ПАНЕЛЬ КНОПОК (в статусе "Урок идет") -->
                            <div class="d-flex flex-wrap align-items-center gap-1 w-100 mb-3 mt-2" invisible="state != 'start'">
                                
                                <!-- Группа кнопок присутствия (Зеленые) -->
                                <button name="action_mass_set_attendance" type="object" string="Присутствуют"
                                        class="btn btn-outline-success btn-sm o_attendance_present_all_btn" 
                                        context="{'set_name': 'Присутствуют'}" icon="fa-check" title="Отметить всех присутствующими"/>

                                <button name="action_mass_set_attendance" type="object" string="Дистанционно"
                                        class="btn btn-outline-success btn-sm" 
                                        context="{'set_name': 'Дистанционно'}" icon="fa-laptop" title="Отметить всех дистанционно"/>

                                <!-- Группа кнопок отсутствия по причине (Синие/Голубые) -->
                                <button name="action_mass_set_attendance" type="object" string="Болеют" 
                                        class="btn btn-outline-info btn-sm"
                                        context="{'set_name': 'Болеют'}" icon="fa-medkit" title="Отметить всех заболевшими"/>

                                <button name="action_mass_set_attendance" type="object" string="Уважительная"
                                        class="btn btn-outline-info btn-sm"
                                        context="{'set_name': 'Уважительная причина'}" icon="fa-envelope-o" title="Отметить всех по уважительной причине"/>

                                <!-- Кнопки опоздания и прогула (Желтый/Красный) -->
                                <button name="action_mass_set_attendance" type="object" string="Опоздали"
                                        class="btn btn-outline-warning btn-sm"
                                        context="{'set_name': 'Опоздали'}" icon="fa-clock-o" title="Отметить всех опоздавшими"/>

                                <button name="action_mass_set_attendance" type="object" string="Прогуляли"
                                        class="btn btn-outline-danger btn-sm"
                                        context="{'set_name': 'Прогуляли'}" icon="fa-times" title="Отметить всех прогулявшими"/>

                                <!-- Кнопка СБРОС (Прижата вправо через ms-auto) -->
                                <button name="action_reset_attendance_sheet" type="object" string="Сбросить журнал"
                                        class="btn btn-link btn-sm text-danger ms-auto"
                                        icon="fa-refresh" title="Очистить все оценки и статусы"
                                        confirm="Вы уверены, что хотите полностью очистить этот журнал?"/>
                            </div>


                            <field name="attendance_line" colspan="4" nolabel="1"
                                readonly="state != 'start'">
                                <list string="Attendance Line" editable="top" create="false">

                                    <!-- 1. Аватар (можно скрыть) -->
                                    <field name="student_avatar" widget="image"                                    
                                        options="{'size': [32, 32]}"
                                        width="35px"
                                        class="rounded-circle" string="" optional="show" />

                                    <!-- 2. Ученик (Обычно всегда виден, но добавил опцию) -->
                                    <field name="student_id" readonly="1" decoration-bf="1"
                                        options="{'no_open': True}" optional="show" />
                                    
                                    <!-- 3. Оценки -->
                                    <field name="grade_1_ui" string="Оценка 1" 
                                        widget="selection_badge" 
                                        width="70px" optional="show"
                                        decoration-bf="1"
                                        decoration-success="grade_1_ui == '5'"
                                        decoration-info="grade_1_ui == '4'"
                                        decoration-warning="grade_1_ui == '3'"
                                        decoration-danger="grade_1_ui == '2'" />


                                    <field name="grade_2_ui" string="Оценка 2" 
                                        widget="selection_badge"
                                        width="70px" optional="show"
                                        decoration-bf="1"
                                        decoration-success="grade_2_ui == '5'"
                                        decoration-info="grade_2_ui == '4'"
                                        decoration-warning="grade_2_ui == '3'"
                                        decoration-danger="grade_2_ui == '2'" />

                                    <field name="grade_3_ui" string="Оценка 3" 
                                        widget="selection_badge"
                                        width="70px" optional="hide"
                                        decoration-bf="1"
                                        decoration-success="grade_3_ui == '5'"
                                        decoration-info="grade_3_ui == '4'"
                                        decoration-warning="grade_3_ui == '3'"
                                        decoration-danger="grade_3_ui == '2'" />

                                    <!-- 4. Посещаемость -->
                                    <field name="attendance_type_id"
                                        string="Статус"
                                        widget="selection_badge" width="350px"
                                        optional="show"
                                        decoration-bf="1"
                                        decoration-success="present == True and late == False"
                                        decoration-warning="late == True"
                                        decoration-info="absent == True and excused == True"
                                        decoration-danger="absent == True and excused == False"
                                        options="{'horizontal': true}" />


                                    <!-- 5. Примечание (можно скрыть) -->
                                    <field name="remark" placeholder="Примечание..." optional="show" />


                                    <!-- КНОПКА ОЧИСТКИ СТРОКИ -->
                                    <button name="action_clear_line_data"
                                            width="30px" 
                                            type="object" 
                                            icon="fa-eraser" 
                                            title="Очистить" 
                                            class="text-danger"
                                            invisible="parent.state in ('done','cancel')"/>

                                    <!-- 6. Технические невидимые поля (Необходимы для логики
                                    декораций) -->                                    
                                    <field name="present" column_invisible="True" />
                                    <field name="absent" column_invisible="True" />
                                    <field name="late" column_invisible="True" />
                                    <field name="excused" column_invisible="True" />
                                    <field name="grade_1" column_invisible="True" />
                                    <field name="grade_2" column_invisible="True" />
                                    <field name="grade_3" column_invisible="True" />
                                    
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- 3. PIVOT (СВОДНАЯ ТАБЛИЦА) -->
    <record id="view_op_attendance_sheet_pivot" model="ir.ui.view">
        <field name="name">op.attendance.sheet.pivot</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <pivot string="Аналитика ведомостей" display_quantity="1">
                <field name="batch_id" type="row" />
                <field name="subject_id" type="row" />
                <field name="faculty_id" type="row" />
                <field name="attendance_date" interval="month" type="col" />

                <!-- МЕРЫ -->
                <field name="attendance_rate" type="measure" string="Явка (%)" />
                <field name="total_present" type="measure" string="Явка (чел.)" />
                <field name="total_absent" type="measure" string="Неявка (чел.)" />
                <field name="total_students" type="measure" string="Всего (чел.)" />
            </pivot>
        </field>
    </record>

    <!-- 4. ГРАФИК -->
    <record model="ir.ui.view" id="view_op_attendance_sheet_graph">
        <field name="name">op.attendance.sheet.graph</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <graph string="Посещаемость" type="line" sample="1">
                <field name="attendance_date" interval="week" string="Неделя" />
                <field name="attendance_rate" type="measure" string="Явка (%)" />
            </graph>
        </field>
    </record>

    <!-- 5. КАНБАН -->
    <record id="view_op_attendance_sheet_kanban" model="ir.ui.view">
        <field name="name">op.attendance.sheet.kanban</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <kanban default_group_by="days_id" default_order="start_datetime asc, batch_id" quick_create="false">
                <field name="attendance_rate" />
                <field name="count_5" />
                <field name="count_4" />
                <field name="count_3" />
                <field name="count_2" />
                <field name="average_grade_lesson" />
                <field name="total_present" />
                <field name="total_students" />
                <field name="state" />
                <field name="lesson_topic" />

                <templates>
                    <t t-name="card">
                        <!-- Добавляем p-0, чтобы контролировать отступы внутри вручную через
                        внутренний div -->
                        <div
                            t-attf-class="shadow-sm border-0 border-start border-4 #{
                            record.state.raw_value == 'confirm' ? 'border-info' : 
                            record.state.raw_value == 'start' ? 'border-primary' : 
                            record.state.raw_value == 'done' ? 'border-success' : 
                            record.state.raw_value == 'cancel' ? 'border-danger' : 'border-secondary'}">

                            <!-- Основной контейнер с паддингом p-3 (16px) -->
                            <div class="oe_kanban_content p-3">

                                <!-- Заголовок: Предмет + Аватар -->
                                <div class="d-flex align-items-start justify-content-between mb-2">
                                    <div class="text-truncate">
                                        <strong class="o_kanban_record_title d-block text-truncate"
                                            style="font-size: 1.1rem; color: #714B67;">
                                            <field name="subject_id" />
                                        </strong>
                                    </div>
                                    <field name="faculty_id" widget="many2one_avatar_user" />
                                </div>

                                <!-- Мета-данные: Класс, Дата и Время -->
                                <div
                                    class="d-flex align-items-center flex-wrap text-muted small mb-3"
                                    style="gap: 12px;">
                                    <!-- Класс -->
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-users me-1" title="Класс"
                                            style="opacity: 0.7; font-size: 0.8rem;" />
                                        <field name="batch_id" class="fw-bold text-dark" />
                                    </div>

                                    <!-- Дата -->
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-calendar me-1" title="Дата"
                                            style="opacity: 0.7; font-size: 0.8rem;" />
                                        <field name="attendance_date" class="fw-bold text-dark" />
                                    </div>

                                    <!-- Время -->
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-clock-o me-1" title="Время"
                                            style="opacity: 0.7; font-size: 0.8rem;" />
                                        <field name="timing" class="fw-bold text-dark" />
                                    </div>
                                </div>

                                <!-- Тема урока (Блок с пунктиром) -->
                                <div
                                    t-attf-class="p-2 mb-3 rounded border #{record.lesson_topic.value ? 'bg-light border-light' : 'bg-white border-danger'}"
                                    t-attf-style="#{record.lesson_topic.value ? '' : 'border-style: dashed !important; border-width: 1.2px !important;'}">

                                    <t t-if="record.lesson_topic.value">
                                        <div class="text-dark small fw-bold">
                                            <field name="lesson_topic" />
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="text-danger small d-flex align-items-center">
                                            <i class="fa fa-edit me-2" title="Заполните тему" />
                                            <span>Тема не заполнена!</span>
                                        </div>
                                    </t>
                                </div>

                                <!-- Статистика оценок -->
                                <div class="d-flex align-items-center gap-1 mb-3"
                                    t-if="record.count_5.raw_value or record.count_4.raw_value or record.count_3.raw_value or record.count_2.raw_value">
                                    <span t-if="record.count_5.raw_value"
                                        class="badge border bg-white text-success border-success-subtle fw-medium">
                                        5: <t t-out="record.count_5.raw_value" /></span>
                                    <span t-if="record.count_4.raw_value"
                                        class="badge border bg-white text-primary border-primary-subtle fw-medium">
                                        4: <t t-out="record.count_4.raw_value" /></span>
                                    <span t-if="record.count_3.raw_value"
                                        class="badge border bg-white text-warning border-warning-subtle fw-medium">
                                        3: <t t-out="record.count_3.raw_value" /></span>
                                    <span t-if="record.count_2.raw_value"
                                        class="badge border bg-white text-danger border-danger-subtle fw-medium">
                                        2: <t t-out="record.count_2.raw_value" /></span>

                                    <div class="ms-auto d-flex align-items-center text-muted small"
                                        title="Средний балл">
                                        <i class="fa fa-line-chart me-1" style="color: #714B67;" />
                                        <b style="color: #714B67;">
                                            <field name="average_grade_lesson" />
                                        </b>
                                    </div>
                                </div>

                                <!-- Нижняя панель (Футер) -->
                                <div
                                    class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto">
                                    <div class="d-flex align-items-center">
                                        <i class="oi oi-group me-2 text-muted" title="Присутствие"
                                            style="font-size: 0.8rem;" />
                                        <span class="small fw-bold me-2">
                                            <t t-out="record.total_present.raw_value" />/<t
                                                t-out="record.total_students.raw_value" />
                                        </span>
                                        <!-- Прогресс-бар посещаемости -->
                                        <div class="progress"
                                            style="height: 6px; width: 40px; background-color: #f0f0f0;">
                                            <div
                                                t-attf-class="progress-bar #{record.attendance_rate.raw_value >= 90 ? 'bg-success' : record.attendance_rate.raw_value >= 70 ? 'bg-warning' : 'bg-danger'}"
                                                t-attf-style="width: #{record.attendance_rate.raw_value}%"></div>
                                        </div>
                                    </div>

                                    <field name="state" widget="badge"
                                        decoration-info="state == 'confirm'"
                                        decoration-primary="state == 'start'"
                                        decoration-success="state == 'done'"
                                        decoration-danger="state == 'cancel'" />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- 6. ПОИСК -->
    <record id="view_op_attendance_sheet_search" model="ir.ui.view">
        <field name="name">op.attendance.sheet.search</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <search>
                <field name="display_title" string="Название журнала" />
                <field name="batch_id" string="Класс" />
                <field name="subject_id" string="Предмет" />
                <field name="faculty_id" string="Учитель" />

                <!-- Группа 1: ПЕРИОДЫ -->
                <filter string="Текущая неделя" name="this_week"
                    domain="[
                        ('attendance_date', '&gt;=', (context_today() + relativedelta(weeks=-1, days_id=1, weekday=0)).strftime('%Y-%m-%d')),
                        ('attendance_date', '&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d'))]" />

                <filter string="Сегодня" name="today"
                    domain="[('attendance_date', '=', context_today().strftime('%Y-%m-%d'))]" />


                <separator />

                <filter string="👨‍🏫 Мои уроки" name="my_lessons"
                    domain="[('faculty_id.user_id', '=', uid)]" />

                <separator />

                <!-- Группа 2: СОСТОЯНИЕ УРОКА -->
                <filter string="🔵 Утвержден" name="confirm" domain="[('state', '=', 'confirm')]" />
                <filter string="🟣   Идет урок" name="start" domain="[('state', '=', 'start')]" />
                <filter string="🟢 Проведен" name="done" domain="[('state', '=', 'done')]" />
                <filter string="🔴 Отменен" name="cancel" domain="[('state', '=', 'cancel')]" />

                <separator />

                <!-- Группировки (Появятся вверху списка при нажатии на +) -->
                <group expand="0" string="Группировать по...">
                    <filter string="🏫 Класс" name="group_batch" context="{'group_by': 'batch_id'}" />
                    <filter string="📚 Предмет" name="group_subject"
                        context="{'group_by': 'subject_id'}" />
                    <filter string="👨‍🏫 Учитель" name="group_faculty"
                        context="{'group_by': 'faculty_id'}" />
                    <filter string="🕒 Статус" name="group_state" context="{'group_by': 'state'}" />
                    <filter string="🗓️ Дата урока" name="group_date"
                        context="{'group_by': 'attendance_date'}" />
                </group>
                <searchpanel>                    
                    <!-- Фильтр по классам -->
                    <field name="batch_id"
                        expand="0"
                        string="Класс"
                        select="one"
                        icon="fa-users"
                        title="Фильтр по классам"
                        enable_counters="1" />

                    <!-- Фильтр по учителям -->
                    <field name="faculty_id"
                        expand="0"
                        string="Учителя"
                        select="one"
                        icon="fa-graduation-cap"
                        title="Фильтр по учителям"
                        enable_counters="1" />
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- 7. ДЕЙСТВИЕ -->
    <record model="ir.actions.act_window" id="act_open_op_attendance_sheet_view">
        <field name="name">Attendance Sheets</field>
        <field name="res_model">op.attendance.sheet</field>
        <field name="view_mode">kanban,list,pivot,form,graph</field>
        <field name="search_view_id" ref="view_op_attendance_sheet_search" />
        <field name="context">{
            'search_default_this_week': 1,
            'search_default_group_day': 1
            'pivot_measures': ['attendance_rate'],
            }</field>
    </record>
</odoo>