<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 1. СПИСОК (TREE/LIST) -->
    <record id="view_op_attendance_sheet_tree" model="ir.ui.view">
        <field name="name">op.attendance.sheet.list</field>
        <field name="model">op.attendance.sheet</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="Attendance Sheet">
                <field name="register_id"/>
                <field name="name"/>
                <field name="session_id"/>
                <field name="attendance_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- 2. ФОРМА -->
    <record id="view_op_attendance_sheet_form" model="ir.ui.view">
        <field name="name">op.attendance.sheet.form</field>
        <field name="model">op.attendance.sheet</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Attendance Sheet">
                <header>
                    <button type="object" name="attendance_start" invisible="state != 'draft'" string="Attendance Start" class="oe_highlight"/>
                    <button type="object" name="attendance_done" invisible="state != 'start'" string="Attendance Taken" class="oe_highlight"/>
                    <button type="object" name="attendance_draft" invisible="state != 'cancel'" string="Draft" class="oe_highlight"/>
                    <button type="object" name="attendance_cancel" invisible="state not in ('draft','start')" string="Cancel"/>
                    <button type="object" name="attendance_draft" string="Draft" invisible="state not in 'done'" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,start,done"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                    <group>
                        <group>
                            <field name="register_id" readonly="state in ('done','cancel')"/>
                            <field name="session_id" domain="[('course_id','=',course_id),('batch_id','=',batch_id)]" />
                            <field name="course_id" invisible="1"/>
                            <field name="batch_id" invisible="1"/>
                            <field name="lesson_topic"/>
                        </group>
                        <group>
                            <field name="name" readonly="state in ('done','cancel')"/>
                            <field name="attendance_date" readonly="state in ('done','cancel')"/>
                        </group>
                    </group>
                    <group col="4" string="Students">
                        <field name="attendance_line" colspan="4" nolabel="1" readonly="state in ('done','cancel')">
                            <list string="Attendance Line" editable="top">
                                <field name="student_id" domain="[('course_detail_ids.course_id','=',parent.course_id),('course_detail_ids.batch_id','=',parent.batch_id)]"/>
                                <field name="grade_1" sum="Avg Grade 1"/>
                                <field name="grade_2" sum="Avg Grade 2"/>
                                <field name="present"/>
                                <field name="late"/>
                                <field name="excused"/>
                                <field name="absent"/>
                                <field name="remark"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- 3. ПОИСК (Исправлен ID) -->
    <record id="view_op_attendance_sheet_search" model="ir.ui.view">
        <field name="name">op.attendance.sheet.search</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <search>
                <field name="batch_id"/>
                <field name="subject_id"/>
                <field name="faculty_id"/>
                <field name="attendance_date"/>
                
                <filter string="Мои уроки" name="my_lessons" domain="[('faculty_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Сегодня" name="today" domain="[('attendance_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                
                <group expand="0" string="Группировать по...">
                    <filter string="Класс" name="group_batch" context="{'group_by': 'batch_id'}"/>
                    <filter string="Предмет" name="group_subject" context="{'group_by': 'subject_id'}"/>
                    <filter string="Дата" name="group_date" context="{'group_by': 'attendance_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 4. СВОДНАЯ ТАБЛИЦА (PIVOT) -->
    <record id="view_op_attendance_sheet_pivot" model="ir.ui.view">
        <field name="name">op.attendance.sheet.pivot</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <pivot string="Аналитика ведомостей" display_quantity="1">
                <field name="batch_id" type="row"/>
                <field name="subject_id" type="row"/>
                <field name="faculty_id" type="row"/>
                <field name="attendance_date" interval="month" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- 5. ГРАФИК -->
    <record model="ir.ui.view" id="view_op_attendance_sheet_graph">
        <field name="name">op.attendance.sheet.graph</field>
        <field name="model">op.attendance.sheet</field>
        <field name="arch" type="xml">
            <graph string="Attendance Sheet" type="pie">
                <field name="batch_id"/>
            </graph>
        </field>
    </record>

    <!-- 6. ДЕЙСТВИЕ (ACTION) -->
    <record model="ir.actions.act_window" id="act_open_op_attendance_sheet_view">
        <field name="name">Attendance Sheets</field>
        <field name="res_model">op.attendance.sheet</field>
        <field name="view_mode">list,pivot,form,graph</field>
        <field name="search_view_id" ref="view_op_attendance_sheet_search"/>
        <field name="context">{
            'search_default_today': 1,
            'search_default_group_batch': 1
        }</field>
    </record>
</odoo>