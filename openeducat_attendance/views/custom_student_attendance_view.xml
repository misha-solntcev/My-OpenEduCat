<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Наследуемое представление для добавления кастомных групп к кнопке Attendance для ученика -->
    <record id="student_form_attendance_custom_groups" model="ir.ui.view">
        <field name="name">op.student.form.attendance.custom.groups</field>
        <field name="model">op.student</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_student_form_attendance_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='get_attendance']" position="attributes">
                <attribute name="groups">openeducat_attendance.group_op_attendance_user,openeducat_attendance.group_op_attendance_manager,__custom__.group_op_faculty,__custom__.group_op_students</attribute>
            </xpath>
        </field>
    </record>
</odoo>