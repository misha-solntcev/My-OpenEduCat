<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 1. СПИСОК (Для детального просмотра) -->
    <record id="view_op_attendance_line_tree" model="ir.ui.view">
        <field name="name">op.attendance.line.list</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <list string="Журнал оценок" editable="bottom">
                <field name="attendance_date" optional="show" readonly="1"/>
                <field name="term_id" optional="hide" readonly="1"/>
                <field name="student_id" optional="show" readonly="1" options="{'no_open': True}"/>
                <field name="batch_id" string="Класс" optional="show" readonly="1"/>
                <field name="subject_id" optional="show" readonly="1" options="{'no_open': True}"/>
                
                <field name="grade_1" string="Оценка 1" optional="show"
                       decoration-success="grade_1 &gt;= 4.5"
                       decoration-info="grade_1 &gt;= 3.5 and grade_1 &lt; 4.5"
                       decoration-warning="grade_1 &gt;= 2.5 and grade_1 &lt; 3.5"
                       decoration-danger="grade_1 &lt; 2.5 and grade_1 &gt; 0"/>

                <field name="grade_2" string="Оценка 2" optional="show"
                       decoration-success="grade_2 &gt;= 4.5"
                       decoration-info="grade_2 &gt;= 3.5 and grade_2 &lt; 4.5"
                       decoration-warning="grade_2 &gt;= 2.5 and grade_2 &lt; 3.5"
                       decoration-danger="grade_2 &lt; 2.5 and grade_2 &gt; 0"/>

                <field name="grade_3" string="Оценка 3" optional="hide"
                       decoration-success="grade_3 &gt;= 4.5"
                       decoration-info="grade_3 &gt;= 3.5 and grade_3 &lt; 4.5"
                       decoration-warning="grade_3 &gt;= 2.5 and grade_3 &lt; 3.5"
                       decoration-danger="grade_3 &lt; 2.5 and grade_3 &gt; 0"/>

                <field name="grade_avg" string="Средняя" widget="badge" optional="show"
                       decoration-success="grade_avg &gt;= 4.5"
                       decoration-info="grade_avg &gt;= 3.5 and grade_avg &lt; 4.5"
                       decoration-warning="grade_avg &gt;= 2.5 and grade_avg &lt; 3.5"
                       decoration-danger="grade_avg &lt; 2.5 and grade_avg &gt; 0"/>
                
                <field name="remark" optional="show"/>                
            </list>
        </field>
    </record>

    <!-- 2. Электронный дневник-->
    <record id="view_op_attendance_line_pivot" model="ir.ui.view">
        <field name="name">op.attendance.line.pivot</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <pivot string="Электронный дневник" display_quantity="0" >
                <!-- Описываем структуру дерева в строках -->
                <field name="academic_year_id" type="row"/>
                <field name="parent_term_id" type="row"/>
                <field name="term_id" type="row"/>
                <field name="batch_id" type="row"/>
                <field name="student_id" type="row"/>

                <!-- Колонки (группировка сверху) -->
                <field name="subject_id" type="col"/>

                <!-- Значение: Средний балл -->
                <field name="grade_avg" type="measure"/>
                <field name="grade_1" type="measure"/>
                <field name="grade_2" type="measure"/>
                <field name="grade_3" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- 3. ПОИСК -->
    <record id="view_op_attendance_line_search" model="ir.ui.view">
        <field name="name">op.attendance.line.search</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id" string="Ученик"/>
                <field name="batch_id" string="Класс"/>
                <field name="subject_id" string="Предмет"/>
                <field name="faculty_id" string="Учитель"/>
                
                <filter string="📅 Текущий год" name="curr_year"
                        domain="[('academic_year_id.start_date', '&lt;=', context_today().strftime('%Y-%m-%d')),
                                ('academic_year_id.end_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                
                <filter string="🔔 Текущая четверть" name="curr_term"
                        domain="[('term_id.term_start_date', '&lt;=', context_today().strftime('%Y-%m-%d')),
                                ('term_id.term_end_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                
                <separator/>

                <filter string="👨‍🏫 Мои уроки" name="my_lessons" domain="[('faculty_id.user_id', '=', uid)]"/>
                
                <separator/>
                
                <!-- Фильтры по оценкам с иконками -->
                <filter string="🟢 Пятерки (4.5-5.0)" name="grade_5" 
                        domain="[('grade_avg', '&gt;=', 4.5)]"/>                
                <filter string="🔵 Четверки (3.5-4.5)" name="grade_4" 
                        domain="[('grade_avg', '&gt;=', 3.5), ('grade_avg', '&lt;', 4.5)]"/>                
                <filter string="🟡 Тройки (2.5-3.5)" name="grade_3" 
                        domain="[('grade_avg', '&gt;=', 2.5), ('grade_avg', '&lt;', 3.5)]"/>                
                <filter string="🔴 Двойки (1.0-2.5)" name="grade_2" 
                        domain="[('grade_avg', '&gt;=', 1.0), ('grade_avg', '&lt;', 2.5)]"/>
                               
                                
                <group expand="0" string="Группировать по...">
                    <filter string="🏫 Класс" name="group_class" context="{'group_by':'batch_id'}"/>
                    <filter string="👤 Ученик" name="group_student" context="{'group_by':'student_id'}"/>
                    <filter string="📚 Предмет" name="group_subject" context="{'group_by':'subject_id'}"/>
                    <filter string="🕒 Четверть" name="group_term" context="{'group_by':'term_id'}"/>                    
                    <filter string="🗓️ Период" name="group_date" context="{'group_by':'attendance_date'}"/>
                </group>
            </search>
        </field>
    </record>

        <!-- 4. ДЕЙСТВИЕ (Автоматическая сборка отчета) -->
        <record model="ir.actions.act_window" id="act_open_op_attendance_line_view">
            <field name="name">Электронный дневник</field>
            <field name="res_model">op.attendance.line</field>
            <field name="view_mode">pivot,list</field>
            <field name="search_view_id" ref="view_op_attendance_line_search"/>
            <field name="domain">[
                ('term_id', '!=', False), 
                ('subject_id', '!=', False), 
                '|', '|', ('grade_1', '>', 0), ('grade_2', '>', 0), ('grade_3', '>', 0)
            ]</field>
            <field name="context">{
                'search_default_curr_year': 1,
                'pivot_row_groupby': ['academic_year_id', 'term_id', 'batch_id'],
                'pivot_col_groupby': ['subject_id'],
                'pivot_measures': ['grade_avg'], 
            }</field>
        </record>
    </odoo>