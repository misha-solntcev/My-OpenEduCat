<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 1. СПИСОК (Для детального просмотра) -->
    <record id="view_op_attendance_line_tree" model="ir.ui.view">
        <field name="name">op.attendance.line.list</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <list string="Журнал оценок" editable="bottom">
                <field name="attendance_date" optional="show" readonly="1"/>
                <field name="student_id" optional="show" readonly="1"/>
                <field name="subject_id" optional="show" readonly="1"/>
                <field name="grade_1" string="Оценка 1" optional="show"/>
                <field name="grade_2" string="Оценка 2" optional="show"/>
                <field name="grade_3" string="Оценка 3" optional="hide"/>
                <field name="batch_id" optional="show"/>
                <field name="term_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- 2. СВОДНАЯ ТАБЛИЦА (МАТРИЦА УСПЕВАЕМОСТИ) -->
    <record id="view_op_attendance_line_pivot" model="ir.ui.view">
        <field name="name">op.attendance.line.pivot</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <pivot string="Сводная ведомость" display_quantity="0" >
                <!-- Описываем структуру дерева в строках -->
                <field name="academic_year_id" type="row"/>
                <field name="parent_term_id" type="row"/>
                <field name="term_id" type="row"/>
                <field name="batch_id" type="row"/>
                <field name="student_id" type="row"/>

                <!-- Предметы всегда в колонках -->
                <field name="subject_id" type="col"/>

                <!-- Значение: Средний балл -->
                <field name="grade_1" type="measure" string="Ср.балл"/>
            </pivot>
        </field>
    </record>

    <!-- 3. ПОИСК -->
    <record id="view_op_attendance_line_search" model="ir.ui.view">
        <field name="name">op.attendance.line.search</field>
        <field name="model">op.attendance.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="batch_id" string="Класс"/>
                <field name="subject_id" string="Предмет"/>
                <filter string="Текущий год" name="curr_year"
                        domain="[('academic_year_id.start_date', '&lt;=', context_today().strftime('%Y-%m-%d')),
                        ('academic_year_id.end_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                </search>
            </field>
        </record>

        <!-- 4. ДЕЙСТВИЕ (Автоматическая сборка отчета) -->
        <record model="ir.actions.act_window" id="act_open_op_attendance_line_view">
            <field name="name">Сводная ведомость</field>
            <field name="res_model">op.attendance.line</field>
            <field name="view_mode">pivot,list</field>
            <field name="search_view_id" ref="view_op_attendance_line_search"/>
            <!--
            Скрываем пустые записи (без оценок) и без периодов,
            чтобы не было "Ничего" и "Нет".
            -->
            <field name="domain">[('grade_1', '>', 0), ('term_id', '!=', False), ('subject_id', '!=', False)]</field>
            <field name="context">{
                'search_default_curr_year': 1,
                'pivot_row_groupby': ['academic_year_id', 'parent_term_id', 'term_id', 'batch_id', 'student_id'],
                'pivot_col_groupby': ['subject_id'],
                'pivot_measures': ['grade_1'],
                }</field>
        </record>
    </odoo>