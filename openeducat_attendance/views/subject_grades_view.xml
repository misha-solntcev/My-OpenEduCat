    <!-- ПОИСК И ГРУППИРОВКА (Исправлено) -->
    <record id="view_op_subject_grades_search" model="ir.ui.view">
        <field name="name">op.subject.grades.search</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <search>
                <!-- Поля для быстрого поиска текстом -->
                <field name="student_id" string="Ученик"/>
                <field name="subject_id" string="Предмет"/>
                <field name="batch_id" string="Класс"/>
                <field name="faculty_id" string="Учитель"/>

                <!-- Быстрые фильтры -->
                <filter string="Успевающие (>= 4.5)" name="excellent" domain="[('average_mark', '>=', 4.5)]"/>
                <filter string="В зоне риска (&lt; 3.0)" name="risk" domain="[('average_mark', '&lt;', 3.0), ('average_mark', '>', 0)]"/>
                <separator/>
                <filter string="Плохая посещаемость" name="low_attendance" domain="['&amp;', ('total_classes', '>', 0), ('present_classes', '&lt;', 5)]"/>

                <!-- Группировка (появятся в меню "Группировать по") -->
                <group expand="0" string="Группировать по...">
                    <filter string="Класс" name="group_batch" context="{'group_by':'batch_id'}"/>
                    <filter string="Ученик" name="group_student" context="{'group_by':'student_id'}"/>
                    <filter string="Предмет" name="group_subject" context="{'group_by':'subject_id'}"/>
                    <filter string="Учитель" name="group_faculty" context="{'group_by':'faculty_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="act_open_op_subject_grades_view" model="ir.actions.act_window">
        <field name="name">Успеваемость</field>
        <field name="res_model">op.subject.grades</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
