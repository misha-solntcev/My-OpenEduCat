<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- СПИСОК -->
    <record id="view_op_subject_grades_tree" model="ir.ui.view">
        <field name="name">op.subject.grades.tree</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <list string="Оценки">
                <header>
                    <button name="action_migrate_old_data"
                        type="object"
                        string="МИГРИРОВАТЬ ДАННЫЕ"
                        class="btn-primary" />
                    <button name="action_force_recompute" type="object" string="ОБНОВИТЬ СТАТИСТИКУ"
                        class="btn-warning" />
                </header>
                <field name="student_id" />
                <field name="subject_id" />
                <field name="batch_id" />
                <field name="average_mark" string="Средний балл" avg="1" />
            </list>
        </field>
    </record>

    <!-- КАНБАН -->
    <record id="view_op_subject_grades_kanban" model="ir.ui.view">
        <field name="name">op.subject.grades.kanban</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <kanban create="false" group_by="batch_id" class="o_kanban_mobile"
                default_order="student_id, subject_id">
                <field name="student_id" />
                <field name="subject_id" />
                <field name="faculty_id" />
                <field name="average_mark" />
                <field name="total_classes" />
                <field name="present_classes" />
                <field name="textbook_image" />
                <field name="student_name_short" />
                <field name="q1_average_mark" />
                <field name="q2_average_mark" />
                <field name="q3_average_mark" />
                <field name="q4_average_mark" />
                <templates>
                    <t t-name="card">
                        <div class="row g-0">
                            <div class="col-4 d-flex align-items-start justify-content-center p-2">
                                <div style="width: 100px; height: 120px;">
                                    <field name="textbook_image" widget="image"
                                        class="w-100 h-100 object-fit-contain" alt="Книга" />
                                </div>
                            </div>
                            <div class="col-8 p-2">
                                <h5 class="fw-bold mb-1">
                                    <field name="subject_id" />
                                </h5>
                                <div class="d-flex align-items-center mb-1 small text-muted">
                                    <img t-if="record.faculty_id.raw_value"
                                        t-att-src="'/web/image/op.faculty/' + record.faculty_id.raw_value + '/image_128'"
                                        style="width: 20px; height: 20px; border-radius: 50%;"
                                        class="me-1" alt="Учитель" />
                                    <field name="faculty_id" />
                                </div>
                                <div class="d-flex align-items-center mb-2 small fw-bold">
                                    <img t-if="record.student_id.raw_value"
                                        t-att-src="'/web/image/op.student/' + record.student_id.raw_value + '/image_128'"
                                        style="width: 20px; height: 20px; border-radius: 50%;"
                                        class="me-1" alt="Ученик" />
                                    <field name="student_name_short" />
                                </div>
                                <div class="small text-muted mb-1">Баллы по четвертям:</div>
                                <div class="d-flex justify-content-between mb-2 text-center small">
                                    <div>1ч<br /><span
                                            t-attf-class="badge #{record.q1_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q1_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q1_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q1_average_mark" />
                                        </span></div>
                                    <div>2ч<br /><span
                                            t-attf-class="badge #{record.q2_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q2_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q2_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q2_average_mark" />
                                        </span></div>
                                    <div>3ч<br /><span
                                            t-attf-class="badge #{record.q3_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q3_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q3_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q3_average_mark" />
                                        </span></div>
                                    <div>4ч<br /><span
                                            t-attf-class="badge #{record.q4_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q4_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q4_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q4_average_mark" />
                                        </span></div>
                                </div>
                                <div class="progress mb-2" style="height: 8px;">
                                    <t t-set="r"
                                        t-value="record.total_classes.raw_value > 0 ? (record.present_classes.raw_value / record.total_classes.raw_value) : 0" />
                                    <div
                                        t-attf-class="progress-bar #{r >= 0.8 ? 'bg-success' : (r >= 0.6 ? 'bg-warning' : 'bg-danger')}"
                                        t-attf-style="width: #{r * 100}%"></div>
                                </div>
                                <div
                                    class="d-flex justify-content-between align-items-center mt-1 border-top pt-1">
                                    <span class="fw-bold">Общая:</span>
                                    <span
                                        t-attf-class="badge p-2 #{record.average_mark.raw_value >= 4.5 ? 'bg-success' : (record.average_mark.raw_value >= 3.5 ? 'bg-warning' : 'bg-danger')}">
                                        <field name="average_mark" />
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ФОРМА -->
    <record id="view_op_subject_grades_form" model="ir.ui.view">
        <field name="name">op.subject.grades.form</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_migrate_old_data"
                        type="object"
                        string="ПЕРЕНЕСТИ ОЦЕНКИ"
                        class="btn-danger"
                        confirm="Это перенесет оценки из текста в таблицу. Продолжить?" />
                    <button name="action_force_recompute" type="object"
                        string="ПЕРЕСЧИТАТЬ СТАТИСТИКУ" class="btn-primary fw-bold" />
                </header>
                <sheet>
                    <div class="d-flex align-items-start mb-4">
                        <field name="student_avatar" widget="image" class="oe_avatar shadow-sm me-3"
                            style="width: 85px; height: 85px; border-radius: 10%; object-fit: cover;" />
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1">
                                <h1 class="mb-0 fw-bold">
                                    <field name="student_id" readonly="1"
                                        options="{'no_open': True}" />
                                </h1>
                                <div class="text-muted border-start ms-3 ps-3 py-1"
                                    style="font-size: 1.1rem;">
                                    <field name="course_id" options="{'no_open': True}" />
                                </div>
                            </div>
                            <div class="d-flex align-items-center">
                                <h2 class="text-primary mb-0 me-3">
                                    <field name="subject_id" readonly="1" />
                                </h2>
                                <div
                                    class="d-flex align-items-center text-muted border-start ps-3 py-1">
                                    <field name="faculty_avatar" widget="image" class="me-2"
                                        style="width: 40px; height: 40px; border-radius: 10%; border: 1px solid #ddd;" />
                                    <field name="faculty_id" readonly="1"
                                        options="{'no_open': True}" />
                                </div>
                            </div>
                        </div>
                        <div
                            class="ms-auto d-none d-md-flex align-items-center justify-content-center shadow-sm p-1 bg-white border rounded"
                            style="width: 100px; height: 130px;">
                            <field name="textbook_image" widget="image"
                                class="w-100 h-100 object-fit-contain" />
                        </div>
                    </div>

                    <div class="row g-2 mb-4 text-center">
                        <div class="col-6 col-md-3">
                            <div class="border rounded bg-light p-2 h-100 shadow">
                                <div class="text-uppercase small fw-bold text-muted mb-1">Последний
                                    визит</div>
                                <div class="h5 mb-0 fw-bold text-dark">
                                    <field name="last_attendance_date" />
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="border rounded bg-light p-2 h-100 shadow">
                                <div class="text-uppercase small fw-bold text-muted mb-1">
                                    Посещаемость</div>
                                <div class="mb-1"><field name="attendance_rate" widget="badge"
                                        decoration-success="attendance_rate >= 80"
                                        decoration-danger="attendance_rate &lt; 60" /> %</div>
                                <field name="attendance_bar_html" nolabel="1" />
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="border rounded bg-light p-2 h-100 shadow">
                                <div class="text-uppercase small fw-bold text-muted mb-1">Динамика</div>
                                <field name="year_progress_svg" widget="html" nolabel="1" />
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="border rounded bg-light p-2 h-100 shadow d-flex flex-column">
                                <div class="text-uppercase small fw-bold text-muted mb-2 text-center" style="font-size: 1rem; letter-spacing: 0.5px;">
                                    ИТОГО ЗА ГОД
                                </div>

                                <div class="row g-0 align-items-stretch flex-grow-1">
                                    <!-- ЛЕВАЯ ЧАСТЬ: Список четвертей с точками и линией -->
                                    <div class="col-6 position-relative ps-4 d-flex flex-column justify-content-center">
                                        <!-- Вертикальная серая линия-направляющая -->
                                        <div style="position: absolute; left: 9px; top: 10%; bottom: 10%; width: 2px; background: #dee2e6; z-index: 1;" />

                                        <!-- 1 четверть -->
                                        <div class="mb-1 d-flex align-items-baseline" style="position: relative; z-index: 2; font-size: 0.85rem;">
                                            <!-- Зеленая точка (если есть оценка) -->
                                            <div class="rounded-circle shadow-sm" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #28a745;" invisible="not q1_final_grade" />
                                            <!-- Серая точка (если нет оценки) -->
                                            <div class="rounded-circle" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #adb5bd;" invisible="q1_final_grade" />
                                            <span class="text-muted">1 четверть:</span>
                                            <span class="fw-bold text-dark ms-1"><field name="q1_final_grade" readonly="1" placeholder="-"/></span>
                                        </div>

                                        <!-- 2 четверть -->
                                        <div class="mb-1 d-flex align-items-baseline" style="position: relative; z-index: 2; font-size: 0.85rem;">
                                            <div class="rounded-circle shadow-sm" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #28a745;" invisible="not q2_final_grade" />
                                            <div class="rounded-circle" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #adb5bd;" invisible="q2_final_grade" />
                                            <span class="text-muted">2 четверть:</span>
                                            <span class="fw-bold text-dark ms-1"><field name="q2_final_grade" readonly="1" placeholder="-"/></span>
                                        </div>

                                        <!-- 3 четверть -->
                                        <div class="mb-1 d-flex align-items-baseline" style="position: relative; z-index: 2; font-size: 0.85rem;">
                                            <div class="rounded-circle shadow-sm" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #28a745;" invisible="not q3_final_grade" />
                                            <div class="rounded-circle" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #adb5bd;" invisible="q3_final_grade" />
                                            <span class="text-muted">3 четверть:</span>
                                            <span class="fw-bold text-dark ms-1"><field name="q3_final_grade" readonly="1" placeholder="-"/></span>
                                        </div>

                                        <!-- 4 четверть -->
                                        <div class="d-flex align-items-baseline" style="position: relative; z-index: 2; font-size: 0.85rem;">
                                            <div class="rounded-circle shadow-sm" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #28a745;" invisible="not q4_final_grade" />
                                            <div class="rounded-circle" style="width: 12px; height: 12px; position: absolute; left: -20px; border: 2px solid white; background: #adb5bd;" invisible="q4_final_grade" />
                                            <span class="text-muted">4 четверть:</span>
                                            <span class="fw-bold text-dark ms-1"><field name="q4_final_grade" readonly="1" placeholder="-"/></span>
                                        </div>
                                    </div>

                                    <!-- ПРАВАЯ ЧАСТЬ: Итоговая годовая (белый остров) -->
                                    <div class="col-6 p-1">
                                        <div class="bg-white h-100 rounded shadow-sm d-flex flex-column justify-content-center text-center border border-white">
                                            <div class="text-muted small mb-0" style="font-size: 0.6rem; font-weight: 600;">ГОДОВАЯ</div>
                                            <div class="display-4 fw-bolder mb-0" style="color: #714B67; line-height: 1;">
                                                <field name="final_quarter_grade" placeholder="?" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <notebook>
                        <page string="1 четверть" name="q1_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm bg-light rounded-3">
                                        <div class="card-body p-3">
                                            <div
                                                class="text-uppercase small fw-bold text-muted mb-3 text-center">Статистика
                                                оценок</div>
                                            <div class="row g-2 text-center">
                                                <div class="col-3 border-end">
                                                    <div class="h4 mb-0 text-success fw-bold">
                                                        <field name="q1_count_5" />
                                                    </div>
                                                    <small>«5»</small>
                                                </div>
                                                <div class="col-3 border-end">
                                                    <div class="h4 mb-0 text-primary fw-bold">
                                                        <field name="q1_count_4" />
                                                    </div>
                                                    <small>«4»</small>
                                                </div>
                                                <div class="col-3 border-end">
                                                    <div class="h4 mb-0 text-warning fw-bold">
                                                        <field name="q1_count_3" />
                                                    </div>
                                                    <small>«3»</small>
                                                </div>
                                                <div class="col-3">
                                                    <div class="h4 mb-0 text-danger fw-bold">
                                                        <field name="q1_count_2" />
                                                    </div>
                                                    <small>«2»</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="card border-0 shadow-sm h-100 bg-white">
                                        <div class="card-body">
                                            <div
                                                class="text-uppercase small fw-bold text-muted mb-2">Последний
                                                отзыв</div>
                                            <div class="fst-italic text-dark mt-1">
                                                <i
                                                    class="fa fa-quote-left me-2 text-primary opacity-50" />
                                                <field name="q1_last_remark" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="card border-0 shadow-sm h-100 bg-primary text-white">
                                        <div
                                            class="card-body d-flex flex-column justify-content-center">
                                            <div class="small fw-bold opacity-75">ИТОГ ЧЕТВЕРТИ</div>
                                            <div class="display-3 fw-bold">
                                                <field name="q1_final_grade" placeholder="?" />
                                            </div>
                                            <div class="small mt-1 opacity-75">Средний балл: <field
                                                    name="q1_average_mark" /></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info py-2 mb-3 d-flex align-items-center">
                                <i class="fa fa-info-circle fa-lg me-3" />
                                <div>
                                    <strong>Посещаемость:</strong>
                                    <field name="q1_attendance_stats_html" widget="html"
                                        class="d-inline-block ms-2" />
                                </div>
                            </div>
                            <field name="q1_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1" />
                                    <field name="lesson_topic" />
                                    <field name="present" widget="boolean" />
                                    <field name="grade_1" />
                                    <field name="grade_2" />
                                    <field name="grade_3" />
                                    <field name="remark" />
                                </list>
                            </field>
                        </page>
                        <!-- ЧЕТВЕРТЬ 2 -->
                        <page string="2 четверть" name="q2_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm bg-light p-2">
                                        <strong>Оценки: </strong> 5: <field name="q2_count_5" /> |
                                        4: <field name="q2_count_4" /> | 3: <field name="q2_count_3" />
                                        | 2: <field name="q2_count_2" />
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="card border-0 shadow-sm p-2">
                                        <strong>Отзыв: </strong>
                                        <field name="q2_last_remark" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div
                                        class="card border-0 shadow-sm bg-primary text-white p-2 text-center">
                                        <strong>ИТОГ: </strong> <field name="q2_final_grade" />
                                        (балл: <field name="q2_average_mark" />) </div>
                                </div>
                            </div>
                            <div class="alert alert-info py-1 mb-2" role="alert">
                                <field name="q2_attendance_stats_html" widget="html" />
                            </div>
                            <field name="q2_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1" />
                                    <field name="lesson_topic" />
                                    <field name="present" widget="boolean" />
                                    <field name="grade_1" />
                                    <field name="grade_2" />
                                    <field name="grade_3" />
                                    <field name="remark" />
                                </list>
                            </field>
                        </page>

                        <!-- ЧЕТВЕРТЬ 3 -->
                        <page string="3 четверть" name="q3_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm bg-light p-2">
                                        <strong>Оценки: </strong> 5: <field name="q3_count_5" /> |
                                        4: <field name="q3_count_4" /> | 3: <field name="q3_count_3" />
                                        | 2: <field name="q3_count_2" />
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="card border-0 shadow-sm p-2">
                                        <strong>Отзыв: </strong>
                                        <field name="q3_last_remark" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div
                                        class="card border-0 shadow-sm bg-primary text-white p-2 text-center">
                                        <strong>ИТОГ: </strong> <field name="q3_final_grade" />
                                        (балл: <field name="q3_average_mark" />) </div>
                                </div>
                            </div>
                            <div class="alert alert-info py-1 mb-2" role="alert">
                                <field name="q3_attendance_stats_html" widget="html" />
                            </div>
                            <field name="q3_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1" />
                                    <field name="lesson_topic" />
                                    <field name="present" widget="boolean" />
                                    <field name="grade_1" />
                                    <field name="grade_2" />
                                    <field name="grade_3" />
                                    <field name="remark" />
                                </list>
                            </field>
                        </page>

                        <!-- ЧЕТВЕРТЬ 4 -->
                        <page string="4 четверть" name="q4_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm bg-light p-2">
                                        <strong>Оценки: </strong> 5: <field name="q4_count_5" /> |
                                        4: <field name="q4_count_4" /> | 3: <field name="q4_count_3" />
                                        | 2: <field name="q4_count_2" />
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="card border-0 shadow-sm p-2">
                                        <strong>Отзыв: </strong>
                                        <field name="q4_last_remark" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div
                                        class="card border-0 shadow-sm bg-primary text-white p-2 text-center">
                                        <strong>ИТОГ: </strong> <field name="q4_final_grade" />
                                        (балл: <field name="q4_average_mark" />) </div>
                                </div>
                            </div>
                            <div class="alert alert-info py-1 mb-2" role="alert">
                                <field name="q4_attendance_stats_html" widget="html" />
                            </div>
                            <field name="q4_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1" />
                                    <field name="lesson_topic" />
                                    <field name="present" widget="boolean" />
                                    <field name="grade_1" />
                                    <field name="grade_2" />
                                    <field name="grade_3" />
                                    <field name="remark" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="act_open_op_subject_grades_view" model="ir.actions.act_window">
        <field name="name">Успеваемость</field>
        <field name="res_model">op.subject.grades</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>