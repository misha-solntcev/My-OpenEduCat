<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- СПИСОК -->
    <record id="view_op_subject_grades_tree" model="ir.ui.view">
        <field name="name">op.subject.grades.tree</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <list string="Оценки">
                <header>
                    <button name="action_force_recompute" type="object" string="ОБНОВИТЬ СТАТИСТИКУ" class="btn-warning"/>
                    <button name="action_migrate_old_data" type="object" string="Мигрировать данные" class="btn-primary"/>
                </header>
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="batch_id"/>
                <field name="average_mark" string="Средний балл" avg="1"/>
            </list>
        </field>
    </record>

    <!-- КАНБАН -->
    <record id="view_op_subject_grades_kanban" model="ir.ui.view">
        <field name="name">op.subject.grades.kanban</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <kanban create="false" group_by="batch_id" class="o_kanban_mobile" default_order="student_id, subject_id">
                <field name="student_id"/><field name="subject_id"/><field name="faculty_id"/>
                <field name="average_mark"/><field name="total_classes"/><field name="present_classes"/>
                <field name="textbook_image"/><field name="student_name_short"/>
                <field name="q1_average_mark"/><field name="q2_average_mark"/><field name="q3_average_mark"/><field name="q4_average_mark"/>
                <templates>
                    <t t-name="card">
                        <div class="row g-0">
                            <div class="col-4 d-flex align-items-start justify-content-center p-2">
                                <div style="width: 100px; height: 120px;">
                                    <field name="textbook_image" widget="image" class="w-100 h-100 object-fit-contain" alt="Книга"/>
                                </div>
                            </div>
                            <div class="col-8 p-2">
                                <h5 class="fw-bold mb-1"><field name="subject_id"/></h5>
                                <div class="d-flex align-items-center mb-1 small text-muted">
                                    <img t-if="record.faculty_id.raw_value" t-att-src="'/web/image/op.faculty/' + record.faculty_id.raw_value + '/image_128'" style="width: 20px; height: 20px; border-radius: 50%;" class="me-1" alt="Учитель"/>
                                    <field name="faculty_id"/>
                                </div>
                                <div class="d-flex align-items-center mb-2 small fw-bold">
                                    <img t-if="record.student_id.raw_value" t-att-src="'/web/image/op.student/' + record.student_id.raw_value + '/image_128'" style="width: 20px; height: 20px; border-radius: 50%;" class="me-1" alt="Ученик"/>
                                    <field name="student_name_short"/>
                                </div>
                                <div class="small text-muted mb-1">Средний балл по четвертям:</div>
                                <div class="d-flex justify-content-between mb-2 text-center small">
                                    <div>1ч<br/><span t-attf-class="badge #{record.q1_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q1_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q1_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}"><field name="q1_average_mark"/></span></div>
                                    <div>2ч<br/><span t-attf-class="badge #{record.q2_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q2_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q2_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}"><field name="q2_average_mark"/></span></div>
                                    <div>3ч<br/><span t-attf-class="badge #{record.q3_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q3_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q3_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}"><field name="q3_average_mark"/></span></div>
                                    <div>4ч<br/><span t-attf-class="badge #{record.q4_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q4_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q4_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}"><field name="q4_average_mark"/></span></div>
                                </div>
                                <div class="progress mb-2" style="height: 8px;">
                                    <t t-set="r" t-value="record.total_classes.raw_value > 0 ? (record.present_classes.raw_value / record.total_classes.raw_value) : 0"/>
                                    <div t-attf-class="progress-bar #{r >= 0.8 ? 'bg-success' : (r >= 0.6 ? 'bg-warning' : 'bg-danger')}" t-attf-style="width: #{r * 100}%"></div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-1 border-top pt-1">
                                    <span class="fw-bold">Общая:</span>
                                    <span t-attf-class="badge p-2 #{record.average_mark.raw_value >= 4.5 ? 'bg-success' : (record.average_mark.raw_value >= 3.5 ? 'bg-warning' : 'bg-danger')}"><field name="average_mark"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ФОРМА -->
    <record id="view_op_subject_grades_form" model="ir.ui.view">
        <field name="name">op.subject.grades.form</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_force_recompute" type="object" string="ПЕРЕСЧИТАТЬ СТАТИСТИКУ" class="btn-primary fw-bold"/>
                    <button name="action_migrate_old_data" type="object" string="ПЕРЕНЕСТИ ОЦЕНКИ" class="btn-danger"/>
                </header>
                <sheet>
                    <field name="textbook_image" widget="image" class="oe_avatar" alt="Учебник"/>
                    <div class="oe_title">
                        <h1><field name="student_id" readonly="1"/></h1>
                        <h2><field name="subject_id" readonly="1"/></h2>
                    </div>
                    <group>
                        <group string="Итоги">
                            <field name="average_mark" readonly="1"/><field name="total_classes" readonly="1"/><field name="present_classes" readonly="1"/>
                        </group>
                        <group string="Детали">
                            <field name="batch_id" readonly="1"/><field name="faculty_id" readonly="1"/><field name="last_attendance_date" readonly="1"/>
                            <field name="final_quarter_grade" string="Годовая (итог)"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- ПОВТОРЯЮЩИЙСЯ БЛОК ДЛЯ КАЖДОЙ ЧЕТВЕРТИ -->
                        <page string="1 четверть" name="q1_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4"><div class="card shadow-sm border-0 bg-light"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2 text-center">Оценки</div>
                                    <div class="d-flex gap-2 text-center">
                                        <div class="flex-fill border rounded bg-white p-2 text-primary"><div class="fw-bold h4 mb-0"><field name="q1_count_5"/></div><div class="small text-muted">«5»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-success"><div class="fw-bold h4 mb-0"><field name="q1_count_4"/></div><div class="small text-muted">«4»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-warning"><div class="fw-bold h4 mb-0"><field name="q1_count_3"/></div><div class="small text-muted">«3»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-danger"><div class="fw-bold h4 mb-0"><field name="q1_count_2"/></div><div class="small text-muted">«2»</div></div>
                                    </div>
                                </div></div></div>
                                <div class="col-md-5">
                                    <div class="card shadow-sm border-0 h-100 bg-white">
                                        <div class="card-body p-3 text-start">
                                            <div class="text-uppercase small fw-bold text-muted mb-2">Последний отзыв</div>
                                            <!-- text-dark сделает текст черным, font-size чуть увеличит его -->
                                            <div class="fst-italic text-dark mt-2" style="font-size: 1.1em; line-height: 1.4;">
                                                <!-- Синяя иконка (text-primary) и средняя прозрачность -->
                                                <i class="fa fa-quote-left me-2 opacity-50 text-primary" title="Отзыв"/>
                                                <field name="q1_last_remark"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="card shadow-sm border-0 bg-primary text-white h-100 text-center d-flex flex-column justify-content-center">
                                        <div class="text-uppercase small fw-bold opacity-75">Средний / Итог</div>
                                        <div class="h2 fw-bold mb-0">
                                            <field name="q1_average_mark"/>
                                            <span class="mx-2 opacity-50">/</span>
                                            <!-- Золотой цвет и максимальная жирность -->
                                            <field name="q1_final_grade" style="color: #FFD700 !important; font-weight: 900; text-shadow: 1px 1px 2px rgba(0,0,0,0.3);"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <field name="q1_line_ids" readonly="0"><list editable="bottom" create="false" delete="false">
                                <field name="attendance_date" readonly="1"/><field name="lesson_topic" string="Тема урока"/><field name="present" widget="boolean"/>
                                <field name="grade_1"/><field name="grade_2"/><field name="grade_3"/><field name="remark"/>
                            </list></field>
                        </page>

                        <page string="2 четверть" name="q2_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4"><div class="card shadow-sm border-0 bg-light"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2 text-center">Оценки</div>
                                    <div class="d-flex gap-2 text-center">
                                        <div class="flex-fill border rounded bg-white p-2 text-primary"><div class="fw-bold h4 mb-0"><field name="q2_count_5"/></div><div class="small text-muted">«5»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-success"><div class="fw-bold h4 mb-0"><field name="q2_count_4"/></div><div class="small text-muted">«4»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-warning"><div class="fw-bold h4 mb-0"><field name="q2_count_3"/></div><div class="small text-muted">«3»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-danger"><div class="fw-bold h4 mb-0"><field name="q2_count_2"/></div><div class="small text-muted">«2»</div></div>
                                    </div>
                                </div></div></div>
                                <div class="col-md-5"><div class="card shadow-sm border-0 h-100 bg-white"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2">Последний отзыв</div>
                                    <div class="fst-italic text-secondary mt-2"><i class="fa fa-quote-left me-2 opacity-25" title="Отзыв"/><field name="q2_last_remark"/></div>
                                </div></div></div>
                                <div class="col-md-3"><div class="card shadow-sm border-0 bg-primary text-white h-100 text-center d-flex flex-column justify-content-center">
                                    <div class="text-uppercase small fw-bold opacity-75">Средний / Итог</div>
                                    <div class="h2 fw-bold mb-0"><field name="q2_average_mark"/> / <field name="q2_final_grade" class="text-warning fw-bold"/></div>
                                </div></div>
                            </div>
                            <field name="q2_line_ids" readonly="0"><list editable="bottom" create="false" delete="false">
                                <field name="attendance_date" readonly="1"/><field name="lesson_topic" string="Тема урока"/><field name="present" widget="boolean"/>
                                <field name="grade_1"/><field name="grade_2"/><field name="grade_3"/><field name="remark"/>
                            </list></field>
                        </page>

                        <page string="3 четверть" name="q3_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4"><div class="card shadow-sm border-0 bg-light"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2 text-center">Оценки</div>
                                    <div class="d-flex gap-2 text-center">
                                        <div class="flex-fill border rounded bg-white p-2 text-primary"><div class="fw-bold h4 mb-0"><field name="q3_count_5"/></div><div class="small text-muted">«5»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-success"><div class="fw-bold h4 mb-0"><field name="q3_count_4"/></div><div class="small text-muted">«4»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-warning"><div class="fw-bold h4 mb-0"><field name="q3_count_3"/></div><div class="small text-muted">«3»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-danger"><div class="fw-bold h4 mb-0"><field name="q3_count_2"/></div><div class="small text-muted">«2»</div></div>
                                    </div>
                                </div></div></div>
                                <div class="col-md-5"><div class="card shadow-sm border-0 h-100 bg-white"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2">Последний отзыв</div>
                                    <div class="fst-italic text-secondary mt-2"><i class="fa fa-quote-left me-2 opacity-25" title="Отзыв"/><field name="q3_last_remark"/></div>
                                </div></div></div>
                                <div class="col-md-3"><div class="card shadow-sm border-0 bg-primary text-white h-100 text-center d-flex flex-column justify-content-center">
                                    <div class="text-uppercase small fw-bold opacity-75">Средний / Итог</div>
                                    <div class="h2 fw-bold mb-0"><field name="q3_average_mark"/> / <field name="q3_final_grade" class="text-warning fw-bold"/></div>
                                </div></div>
                            </div>
                            <field name="q3_line_ids" readonly="0"><list editable="bottom" create="false" delete="false">
                                <field name="attendance_date" readonly="1"/><field name="lesson_topic" string="Тема урока"/><field name="present" widget="boolean"/>
                                <field name="grade_1"/><field name="grade_2"/><field name="grade_3"/><field name="remark"/>
                            </list></field>
                        </page>

                        <page string="4 четверть" name="q4_page">
                            <div class="row g-3 mb-3">
                                <div class="col-md-4"><div class="card shadow-sm border-0 bg-light"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2 text-center">Оценки</div>
                                    <div class="d-flex gap-2 text-center">
                                        <div class="flex-fill border rounded bg-white p-2 text-primary"><div class="fw-bold h4 mb-0"><field name="q4_count_5"/></div><div class="small text-muted">«5»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-success"><div class="fw-bold h4 mb-0"><field name="q4_count_4"/></div><div class="small text-muted">«4»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-warning"><div class="fw-bold h4 mb-0"><field name="q4_count_3"/></div><div class="small text-muted">«3»</div></div>
                                        <div class="flex-fill border rounded bg-white p-2 text-danger"><div class="fw-bold h4 mb-0"><field name="q4_count_2"/></div><div class="small text-muted">«2»</div></div>
                                    </div>
                                </div></div></div>
                                <div class="col-md-5"><div class="card shadow-sm border-0 h-100 bg-white"><div class="card-body p-3">
                                    <div class="text-uppercase small fw-bold text-muted mb-2">Последний отзыв</div>
                                    <div class="fst-italic text-secondary mt-2"><i class="fa fa-quote-left me-2 opacity-25" title="Отзыв"/><field name="q4_last_remark"/></div>
                                </div></div></div>
                                <div class="col-md-3"><div class="card shadow-sm border-0 bg-primary text-white h-100 text-center d-flex flex-column justify-content-center">
                                    <div class="text-uppercase small fw-bold opacity-75">Средний / Итог</div>
                                    <div class="h2 fw-bold mb-0"><field name="q4_average_mark"/> / <field name="q4_final_grade" class="text-warning fw-bold"/></div>
                                </div></div>
                            </div>
                            <field name="q4_line_ids" readonly="0"><list editable="bottom" create="false" delete="false">
                                <field name="attendance_date" readonly="1"/><field name="lesson_topic" string="Тема урока"/><field name="present" widget="boolean"/>
                                <field name="grade_1"/><field name="grade_2"/><field name="grade_3"/><field name="remark"/>
                            </list></field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ПОИСК И ГРУППИРОВКА (Исправлено) -->
    <record id="view_op_subject_grades_search" model="ir.ui.view">
        <field name="name">op.subject.grades.search</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <search>
                <!-- Поля для быстрого поиска текстом -->
                <field name="student_id" string="Ученик"/>
                <field name="subject_id" string="Предмет"/>
                <field name="batch_id" string="Класс"/>
                <field name="faculty_id" string="Учитель"/>

                <!-- Быстрые фильтры -->
                <filter string="Успевающие (>= 4.5)" name="excellent" domain="[('average_mark', '>=', 4.5)]"/>
                <filter string="В зоне риска (&lt; 3.0)" name="risk" domain="[('average_mark', '&lt;', 3.0), ('average_mark', '>', 0)]"/>
                <separator/>
                <filter string="Плохая посещаемость" name="low_attendance" domain="['&amp;', ('total_classes', '>', 0), ('present_classes', '&lt;', 5)]"/>

                <!-- Группировка (появятся в меню "Группировать по") -->
                <group expand="0" string="Группировать по...">
                    <filter string="Класс" name="group_batch" context="{'group_by':'batch_id'}"/>
                    <filter string="Ученик" name="group_student" context="{'group_by':'student_id'}"/>
                    <filter string="Предмет" name="group_subject" context="{'group_by':'subject_id'}"/>
                    <filter string="Учитель" name="group_faculty" context="{'group_by':'faculty_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="act_open_op_subject_grades_view" model="ir.actions.act_window">
        <field name="name">Успеваемость</field>
        <field name="res_model">op.subject.grades</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>