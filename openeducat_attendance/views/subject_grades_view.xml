<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- СПИСОК -->
    <record id="view_op_subject_grades_tree" model="ir.ui.view">
        <field name="name">op.subject.grades.tree</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <list string="Оценки">
                <header>
                    <button name="action_migrate_old_data" type="object" string="Мигрировать данные" class="btn-primary"/>
                </header>
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="batch_id"/>
                <field name="average_mark" string="Средний балл" avg="1"/>
            </list>
        </field>
    </record>

    <!-- КАНБАН (БЕЗ ЦИКЛОВ И ФУНКЦИЙ PYTHON) -->
    <record id="view_op_subject_grades_kanban" model="ir.ui.view">
        <field name="name">op.subject.grades.kanban</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <kanban create="false" group_by="batch_id" class="o_kanban_mobile" default_order="student_id, subject_id">
                <field name="student_id"/>
                <field name="subject_id"/>
                <field name="faculty_id"/>
                <field name="average_mark"/>
                <field name="total_classes"/>
                <field name="present_classes"/>
                <field name="textbook_image"/>
                <field name="q1_average_mark"/>
                <field name="q2_average_mark"/>
                <field name="q3_average_mark"/>
                <field name="q4_average_mark"/>
                <templates>
                    <t t-name="card">
                        <div class="row g-0">
                            <div class="col-4 d-flex align-items-start justify-content-center p-2">
                                <div style="width: 100px; height: 120px;">
                                    <field name="textbook_image" widget="image" class="w-100 h-100 object-fit-contain" alt="Книга"/>
                                </div>
                            </div>
                            <div class="col-8 p-2">
                                <h5 class="fw-bold mb-1"><field name="subject_id"/></h5>
                                
                                <div class="d-flex align-items-center mb-1 small text-muted">
                                    <img t-if="record.faculty_id.raw_value" t-att-src="'/web/image/op.faculty/' + record.faculty_id.raw_value + '/image_128'" style="width: 20px; height: 20px; border-radius: 50%;" class="me-1" alt="Учитель"/>
                                    <field name="faculty_id"/>
                                </div>
                                <div class="d-flex align-items-center mb-2 small fw-bold">
                                    <img t-if="record.student_id.raw_value" t-att-src="'/web/image/op.student/' + record.student_id.raw_value + '/image_128'" style="width: 20px; height: 20px; border-radius: 50%;" class="me-1" alt="Ученик"/>
                                    <field name="student_name_short"/>
                                </div>

                                <div class="small text-muted mb-1">Средний балл по четвертям:</div>
                                <div class="d-flex justify-content-between mb-2 text-center">
                                    <!-- Четверть 1 -->
                                    <div><div class="small">1ч</div>
                                        <span t-attf-class="badge #{record.q1_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q1_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q1_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q1_average_mark"/>
                                        </span>
                                    </div>
                                    <!-- Четверть 2 -->
                                    <div><div class="small">2ч</div>
                                        <span t-attf-class="badge #{record.q2_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q2_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q2_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q2_average_mark"/>
                                        </span>
                                    </div>
                                    <!-- Четверть 3 -->
                                    <div><div class="small">3ч</div>
                                        <span t-attf-class="badge #{record.q3_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q3_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q3_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q3_average_mark"/>
                                        </span>
                                    </div>
                                    <!-- Четверть 4 -->
                                    <div><div class="small">4ч</div>
                                        <span t-attf-class="badge #{record.q4_average_mark.raw_value >= 4.5 ? 'bg-success' : (record.q4_average_mark.raw_value >= 3.5 ? 'bg-warning' : (record.q4_average_mark.raw_value > 0 ? 'bg-danger' : 'bg-light text-muted'))}">
                                            <field name="q4_average_mark"/>
                                        </span>
                                    </div>
                                </div>

                                <div class="attendance-info mb-2">
                                    <div class="progress" style="height: 8px; background-color: #eee;">
                                        <t t-set="r" t-value="record.total_classes.raw_value > 0 ? (record.present_classes.raw_value / record.total_classes.raw_value) : 0"/>
                                        <div t-attf-class="progress-bar #{r >= 0.8 ? 'bg-success' : (r >= 0.6 ? 'bg-warning' : 'bg-danger')}" t-attf-style="width: #{r * 100}%" role="progressbar"></div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-2">
                                    <span class="fw-bold">Общая:</span>
                                    <span t-attf-class="badge p-2 #{record.average_mark.raw_value >= 4.5 ? 'bg-success' : (record.average_mark.raw_value >= 3.5 ? 'bg-warning' : 'bg-danger')}">
                                        <field name="average_mark"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ФОРМА (РЕДАКТИРУЕМАЯ) -->
    <record id="view_op_subject_grades_form" model="ir.ui.view">
        <field name="name">op.subject.grades.form</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_migrate_old_data" type="object" string="ПЕРЕНЕСТИ ОЦЕНКИ" class="btn-danger"/>
                </header>
                <sheet>
                    <field name="textbook_image" widget="image" class="oe_avatar" alt="Учебник"/>
                    <div class="oe_title">
                        <h1><field name="student_id" readonly="1"/></h1>
                        <h2><field name="subject_id" readonly="1"/></h2>
                    </div>
                    <group>
                        <group string="Итоги">
                            <field name="average_mark" readonly="1"/>
                            <field name="total_classes" readonly="1"/><field name="present_classes" readonly="1"/>
                        </group>
                        <group string="Детали">
                            <field name="batch_id" readonly="1"/><field name="faculty_id" readonly="1"/><field name="last_attendance_date" readonly="1"/>
                            <field name="final_quarter_grade" string="Годовая (итог)"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="1 четверть">
                            <div style="display: flex; gap: 20px; background: #f8f9fa; padding: 15px; border-radius: 10px; border: 1px solid #dee2e6; margin-bottom: 15px;">
                                <div style="width: 260px;">
                                    <span class="badge bg-primary">5: <field name="q1_count_5"/></span>
                                    <span class="badge bg-success ms-1">4: <field name="q1_count_4"/></span>
                                    <span class="badge bg-warning text-dark ms-1">3: <field name="q1_count_3"/></span>
                                    <span class="badge bg-danger ms-1">2: <field name="q1_count_2"/></span>
                                </div>
                                <div style="flex-grow: 1; border-left: 1px solid #ccc; padding-left: 20px;">
                                    <div class="small text-muted italic"><field name="q1_last_remark"/></div>
                                </div>
                                <div class="text-end" style="width: 220px;">
                                    <div class="h3 fw-bold mb-0 text-primary"><field name="q1_average_mark"/> / <field name="q1_final_grade"/></div>
                                </div>
                            </div>
                            <field name="q1_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1" optional="show"/>
                                    <field name="lesson_topic" string="Тема урока" readonly="0" optional="show"/>
                                    <field name="present" widget="boolean" optional="show"/>
                                    <field name="grade_1" optional="show"/>
                                    <field name="grade_2" optional="show"/>
                                    <field name="grade_3" optional="hide" />
                                    <field name="remark" optional="show"/>
                                </list>
                            </field>
                        </page>
                        <page string="2 четверть">
                            <div style="display: flex; gap: 20px; background: #f8f9fa; padding: 15px; border-radius: 10px; border: 1px solid #dee2e6; margin-bottom: 15px;">
                                <div style="width: 260px;">
                                    <span class="badge bg-primary">5: <field name="q2_count_5"/></span>
                                    <span class="badge bg-success ms-1">4: <field name="q2_count_4"/></span>
                                    <span class="badge bg-warning text-dark ms-1">3: <field name="q2_count_3"/></span>
                                    <span class="badge bg-danger ms-1">2: <field name="q2_count_2"/></span>
                                </div>
                                <div style="flex-grow: 1; border-left: 1px solid #ccc; padding-left: 20px;"><div class="fw-bold mt-1"><field name="q2_last_remark"/></div></div>
                                <div class="text-end" style="width: 220px;"><div class="h3 fw-bold text-primary"><field name="q2_average_mark"/> / <field name="q2_final_grade"/></div></div>
                            </div>
                            <field name="q2_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1"/>
                                    <field name="lesson_topic" readonly="0"/>
                                    <field name="present" widget="boolean"/>
                                    <field name="grade_1" /><field name="grade_2" /><field name="remark"/>
                                </list>
                            </field>
                        </page>
                        <page string="3 четверть">
                            <div style="display: flex; gap: 20px; background: #f8f9fa; padding: 15px; border-radius: 10px; border: 1px solid #dee2e6; margin-bottom: 15px;">
                                <div style="width: 260px;">
                                    <span class="badge bg-primary">5: <field name="q3_count_5"/></span>
                                    <span class="badge bg-success ms-1">4: <field name="q3_count_4"/></span>
                                    <span class="badge bg-warning text-dark ms-1">3: <field name="q3_count_3"/></span>
                                    <span class="badge bg-danger ms-1">2: <field name="q3_count_2"/></span>
                                </div>
                                <div style="flex-grow: 1; border-left: 1px solid #ccc; padding-left: 20px;"><div class="fw-bold"><field name="q3_last_remark"/></div></div>
                                <div class="text-end" style="width: 220px;"><div class="h3 fw-bold text-primary"><field name="q3_average_mark"/> / <field name="q3_final_grade"/></div></div>
                            </div>
                            <field name="q3_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1"/>
                                    <field name="lesson_topic" readonly="0"/>
                                    <field name="present" widget="boolean"/>
                                    <field name="grade_1" /><field name="grade_2" /><field name="remark"/>
                                </list>
                            </field>
                        </page>
                        <page string="4 четверть">
                            <div style="display: flex; gap: 20px; background: #f8f9fa; padding: 15px; border-radius: 10px; border: 1px solid #dee2e6; margin-bottom: 15px;">
                                <div style="width: 260px;">
                                    <span class="badge bg-primary">5: <field name="q4_count_5"/></span>
                                    <span class="badge bg-success ms-1">4: <field name="q4_count_4"/></span>
                                    <span class="badge bg-warning text-dark ms-1">3: <field name="q4_count_3"/></span>
                                    <span class="badge bg-danger ms-1">2: <field name="q4_count_2"/></span>
                                </div>
                                <div style="flex-grow: 1; border-left: 1px solid #ccc; padding-left: 20px;"><div class="fw-bold"><field name="q4_last_remark"/></div></div>
                                <div class="text-end" style="width: 220px;"><div class="h3 fw-bold text-primary"><field name="q4_average_mark"/> / <field name="q4_final_grade"/></div></div>
                            </div>
                            <field name="q4_line_ids" readonly="0">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="attendance_date" readonly="1"/>
                                    <field name="lesson_topic" readonly="0"/>
                                    <field name="present" widget="boolean"/>
                                    <field name="grade_1" /><field name="grade_2" /><field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_op_subject_grades_search" model="ir.ui.view">
        <field name="name">op.subject.grades.search</field>
        <field name="model">op.subject.grades</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/><field name="subject_id"/><field name="batch_id"/>
                <group expand="0" string="Группировать по...">
                    <filter string="Ученик" name="group_student" context="{'group_by':'student_id'}"/>
                    <filter string="Класс" name="group_batch" context="{'group_by':'batch_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="act_open_op_subject_grades_view" model="ir.actions.act_window">
        <field name="name">Успеваемость</field>
        <field name="res_model">op.subject.grades</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>