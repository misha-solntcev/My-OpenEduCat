<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Наследуемое представление для добавления кастомных групп к кнопке Attendance Sheet -->
    <record id="attendance_session_form_view_custom_groups" model="ir.ui.view">
        <field name="name">op.attendance.sheet.form.inherit.custom.groups</field>
        <field name="model">op.session</field>
        <field name="inherit_id" ref="openeducat_attendance.attendance_session_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='get_attendance']" position="attributes">
                <attribute name="groups">openeducat_attendance.group_op_attendance_manager,openeducat_attendance.group_op_attendance_user,__custom__.group_op_faculty,__custom__.group_op_students</attribute>
            </xpath>
        </field>
    </record>
</odoo>