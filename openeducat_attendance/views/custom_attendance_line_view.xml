<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Наследуемое представление для изменения формы записи о посещении -->
    <record id="view_op_attendance_line_form_custom" model="ir.ui.view">
        <field name="name">op.attendance.line.form.custom</field>
        <field name="model">op.attendance.line</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_attendance_line_form"/>
        <field name="arch" type="xml">
            <!-- Полностью заменяем содержимое группы формы -->
            <xpath expr="//group" position="replace">
                <group>
                    <group>
                        <!-- Левая колонка в нужном порядке -->
                        <field name="attendance_date"/>
                        <field name="attendance_id" widget="selection"/>
                        <field name="student_id" domain="[('course_detail_ids.course_id','=',course_id),('course_detail_ids.batch_id','=',batch_id)]"/>
                        <field name="batch_id" widget="selection"/>
                        <field name="course_id" widget="selection"/>
                        <field name="remark"/>
                    </group>
                    <group>
                        <!-- Правая колонка в нужном порядке -->
                        <field name="present"/>
                        <field name="late"/>
                        <field name="absent"/>
                        <field name="excused"/>
                        <field name="x_mark" placeholder="Введите оценку"/>
                        <field name="x_behavior" placeholder="Введите поведение"/>
                        <field name="attendance_type_id" options='{"no_open": True}'/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>