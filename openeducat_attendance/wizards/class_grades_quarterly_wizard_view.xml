<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="class_grades_quarterly_form_view">
        <field name="name">class.grades.quarterly.form</field>
        <field name="model">class.grades.quarterly</field>
        <field name="arch" type="xml">
            <form string="Class Grades Quarterly">
                <group col="4">
                    <field name="batch_id"/>
                </group>
                <footer>
                    <button name="print_report" string="Print" type="object" default_focus="1" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_class_grades_quarterly" model="ir.actions.act_window">
        <field name="name">Class Grades Quarterly</field>
        <field name="res_model">class.grades.quarterly</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="openeducat_core.model_op_batch"/>
    </record>

</odoo>