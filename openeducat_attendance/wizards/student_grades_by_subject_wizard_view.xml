<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.ui.view" id="student_grades_by_subject_form_view">
        <field name="name">student.grades.by.subject.form</field>
        <field name="model">student.grades.by.subject</field>
        <field name="arch" type="xml">
            <form string="Student Grades by Subject">
                <group col="4">
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>
                <footer>
                    <button name="print_report" string="Print" type="object" default_focus="1" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>