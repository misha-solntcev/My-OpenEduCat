<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Определение wizard для обновления оценок -->
    <record id="view_op_update_subject_grades_form" model="ir.ui.view">
        <field name="name">op.update.subject.grades.form</field>
        <field name="model">op.update.subject.grades</field>
        <field name="arch" type="xml">
            <form string="Update Subject Grades">
                <group>
                    <p>Это действие обновит все агрегированные данные по оценкам студентов по предметам.</p>
                    <p>Процесс может занять несколько минут в зависимости от объема данных.</p>
                </group>
                <footer>
                    <button string="Отмена" class="btn-secondary" special="cancel"/>
                    <button string="Обновить" type="object" name="update_subject_grades" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Действие для wizard -->
    <record id="action_op_update_subject_grades" model="ir.actions.act_window">
        <field name="name">Обновить оценки по предметам</field>
        <field name="res_model">op.update.subject.grades</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_op_update_subject_grades_form"/>
    </record>

    <!-- Добавляем пункт меню для wizard -->
    <menuitem id="menu_op_update_subject_grades"
              name="Обновить оценки по предметам"
              parent="openeducat_attendance.menu_op_attendance_config"
              sequence="20"
              action="action_op_update_subject_grades"
              groups="openeducat_attendance.group_op_attendance_manager"/>
</odoo>