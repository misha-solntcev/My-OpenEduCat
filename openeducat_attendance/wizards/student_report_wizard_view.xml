<odoo>
    <record id="view_student_report_wizard_form" model="ir.ui.view">
        <field name="name">student.report.wizard.form</field>
        <field name="model">student.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Итоговые оценки">
                <group>                    
                    <field name="academic_year_id" options="{'no_create': True, 'no_open': True}"/>
                    <!-- Поле переименовано, добавлен виджет тегов -->
                    <field name="batch_ids" 
                        widget="many2many_tags"
                        options="{'no_create': True, 'no_open': True}"
                        placeholder="Все классы школы"/>
                    <!-- В domain заменено batch_id на batch_ids и '=' на 'in' -->
                    <field name="student_ids" 
                        widget="many2many_tags" 
                        options="{'no_create': True}"
                        domain="batch_ids and [('course_detail_ids.batch_id', 'in', batch_ids)] or []"
                        placeholder="Весь класс"/>
                </group>
                <footer>
                    <button name="action_print_report" string="Сформировать PDF" type="object" class="btn-primary"/>
                    <button string="Отмена" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_student_report_wizard" model="ir.actions.act_window">
        <field name="name">Итоговые оценки</field>
        <field name="res_model">student.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_student_summary_report"
              name="Итоговые  оценки"
              parent="openeducat_attendance.menu_op_attendance_reports"
              action="action_student_report_wizard"
              sequence="30"
              groups="openeducat_attendance.group_op_attendance_user,openeducat_attendance.group_op_attendance_manager"/>
</odoo>