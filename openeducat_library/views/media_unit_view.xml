<?xml version="1.0" encoding="UTF-8"?>

<odoo>
        <record id="view_media_unit_tree" model="ir.ui.view">
            <field name="name">op.media.unit.list</field>
            <field name="model">op.media.unit</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Экземпляры"
                      decoration-success="state == 'available'"
                      decoration-info="state == 'issue'"
                      decoration-warning="state == 'reserve'"
                      decoration-danger="state == 'lost'">
                    <field name="name" string="📖  Название экземпляра" optional="show"/>                    
                    <field name="subject_ids" string="📚 Предмет" optional="show" widget="many2many_tags"/>
                    <field name="course_ids" string="🏫 Класс" optional="show" widget="many2many_tags"/>
                    <field name="current_partner_id" string="👨‍🎓 Абонент" optional="show"/>                    
                    <field name="barcode" string="│█║▌Штрих-код" optional="show"/>
                    <field name="isbn" string="🪧 ISBN" optional="show"/>
                    <field name="edition" string="📕 Издание" optional="show"/>
                    <field name="x_issue_year" string="📅 Год выпуска" optional="show"/>
                    <field name="state" string="🔖 Статус" optional="show" widget="badge"
                           decoration-success="state == 'available'"
                           decoration-info="state == 'issue'"
                           decoration-warning="state == 'reserve'"
                           decoration-danger="state == 'lost'"/>
                </list>
            </field>
        </record>

        <record id="view_media_unit_form" model="ir.ui.view">
            <field name="name">op.media.unit.form</field>
            <field name="model">op.media.unit</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Экземпляры">
                    <header groups="base.group_user">
                        <button name="%(issue_media_act)d" string="Выдать книгу"
                                type="action"
                                context="{'default_media_id': media_id, 'default_media_unit_id': id}"
                                invisible= "state != 'available'"
                                class="oe_highlight" groups="openeducat_library.group_op_library"/>
                        <button name="%(return_media_act)d" string="Вернуть книгу"
                                type="action"
                                context="{'default_media_id': media_id, 'default_media_unit_id': id}"
                                invisible= "state != 'issue'"
                                class="oe_highlight" groups="openeducat_library.group_op_library"/>
                        <field name="state" widget="statusbar" statusbar_visible="available,issue,reserve,lost"
                               statusbar_colors='{"r":"red"}'/>
                    </header>
                    <sheet>
                        <field name="active" invisible="1"/>
                        <widget name="web_ribbon" title="В архиве" bg_color="bg-danger"
                                invisible="active == True"/>
                        <group>
                            <group>
                                <field name="name" string="Экземпляр"/>
                                <field name="barcode" readonly="1"/>
                                <field name="isbn" string="ISBN"/>
                            </group>
                            <group>
                                <field name="media_id" string="Книга"/>
                                <field name="media_type_id" string="Тип"/>
                                <field name="edition" string="Издание"/>
                                <field name="x_issue_year" string="Год выпуска"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="movements" string="Movements" >
                                <field name="movement_lines" nolabel='1'>
                                    <list create='false' editable="top">
                                        <field name="library_card_id"/>
                                        <field name="partner_id"/>
                                        <field name="media_id"/>
                                        <field name="media_unit_id"/>
                                        <field name="issued_date"/>
                                        <field name="return_date"/>
                                        <field name="actual_return_date"/>
                                        <field name="state"/>
                                        <field name="invoice_id"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_media_unit_search" model="ir.ui.view">
            <field name="name">op.media.unit.search</field>
            <field name="model">op.media.unit</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <search string="Экземпляры">
                    <field name="barcode" string="│█║▌Штрихкод"/>
                    <field name="name" string="📖 Название книги"/>
                    <field name="isbn" string="🪧 ISBN"/>
                    <field name="subject_ids" string="📚 Предмет"/>
                    <field name="course_ids" string="🏫 Класс"/>
                    <field name="current_partner_id" string="👨‍🎓 Абонент"/>
                    <field name="author_ids" string="✍️ Автор"/>
                    <field name="publisher_ids" string="🏢 Издательство"/>
                    <field name="media_type_id" string="📦 Тип"/>
                    <separator/>
                    <filter string="🟢 Доступна" name="available"
                            domain="[('state', '=', 'available')]"/>
                    <filter string="🔵 Выдана" name="issued"
                            domain="[('state', '=', 'issue')]"/>
                    <filter string="🟡 Зарезервирована" name="reserve"
                            domain="[('state', '=', 'reserve')]"/>
                    <filter string="🔴 Утеряна" name="lost"
                            domain="[('state', '=', 'lost')]"/>
                    <separator/>
                    <filter string="🗃️ В архиве" name="inactive"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Группировка...">
                        <filter string="📖 Название книги" name="group_bymedia"
                            domain="[]" context="{'group_by':'media_id'}"/>
                        <filter string="📚 Предмет" name="group_by_subject"
                            domain="[]" context="{'group_by':'subject_ids'}"/>
                        <filter string="🏫 Класс" name="group_by_course"
                            domain="[]" context="{'group_by':'course_ids'}"/>
                        <filter string="👨‍🎓 Абонент" name="group_by_current_partner"
                            domain="[]" context="{'group_by':'current_partner_id'}"/>
                        <filter string="✍️ Автор" name="group_by_author"
                                domain="[]" context="{'group_by':'author_ids'}"/>
                        <filter string="🏢 Издательство" name="group_by_publisher"
                                domain="[]" context="{'group_by':'publisher_ids'}"/>
                        <filter string="📦 Тип" name="group_by_type"
                                domain="[]" context="{'group_by':'media_type_id'}"/>
                        <filter string="🔖  Статус" name="group_by_state"
                                domain="[]" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_media_unit_view">
            <field name="name">Экземпляры</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">op.media.unit</field>
            <field name="view_mode">list,form</field>
            <field name= "context">{
                'search_default_group_by_course': 1,
                'search_default_group_by_current_partner': 1}
            </field>
        </record>

</odoo>
