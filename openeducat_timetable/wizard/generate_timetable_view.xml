<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="view_gen_time_table_line_tree" model="ir.ui.view">
            <field name="name">gen.time.table.line.list</field>
            <field name="model">gen.time.table.line</field>
            <field name="arch" type="xml">
                <list string="Session Line" editable="bottom">
                    <field name="day" column_invisible="True"/>
                    <field name="timing_id" string="Урок" width="100px" options="{'no_create': True, 'no_open': True}"/>
                    <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                    <field name="faculty_subject_ids" column_invisible="True"/>
                    <field name="subject_id" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                    <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                </list>
            </field>
        </record>

        <record id="view_generate_time_table_form" model="ir.ui.view">
            <field name="name">generate.time.table.form</field>
            <field name="model">generate.time.table</field>
            <field name="arch" type="xml">
                <form string="Создание расписания">
                    <sheet>
                        <!-- ВЕРХНИЙ БЛОК: Поля и общая очистка -->
                        <group name="main_config" class="mt-0">
                            <group col="2">
                                <field name="course_id" string="Класс" options="{'no_create': True, 'no_open': True}"/>
                                <field name="batch_id" string="Параллель" context="{'course_id': course_id, 'get_parent_batch': 1}" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group col="1">
                                <label for="start_date" string="Период"/>
                                <div class="o_row">
                                    <field name="start_date" widget="date" class="oe_inline"/>
                                    <i class="fa fa-long-arrow-right mx-2 text-muted" title="до"/>
                                    <field name="end_date" widget="date" class="oe_inline"/>
                                </div>
                            </group>
                        </group>

                        <!-- БЛОК ИМПОРТА И ОБЩЕЙ ОЧИСТКИ -->
                        <div class="alert alert-info d-flex align-items-center py-1 px-3 mb-2" role="alert">
                            <!-- Текст слева -->
                            <div class="flex-grow-1 small">
                                <i class="fa fa-copy me-1" title="Импорт"/> 
                                <strong>Импорт:</strong> выберите период
                            </div>

                            <!-- Блок управления справа -->
                            <div class="d-flex align-items-center">
                                <!-- Текст "С" и "По" — черные и четкие -->
                                <span class="me-2 text-dark" style="font-weight: 500;">С</span>
                                <field name="import_start_date" nolabel="1" style="width: 115px !important;"/>
                                
                                <span class="mx-2 text-dark" style="font-weight: 500;">По</span>
                                <field name="import_end_date" nolabel="1" style="width: 115px !important;"/>

                                <!-- Кнопка "Заполнить" — фиолетовая (основная) -->
                                <button name="action_import_last_week" type="object" string="Заполнить" 
                                        class="btn-primary btn-sm ms-3 me-2" icon="fa-refresh" 
                                        invisible="not import_start_date or not import_end_date"/>
                                
                                <!-- Кнопка "Очистить всё" — серенькая (второстепенная) -->
                                <button name="action_clear_all" type="object" string="Очистить всё" 
                                        class="btn-secondary btn-sm" icon="fa-trash" 
                                        confirm="Вы уверены, что хотите полностью очистить таблицу?"/>
                            </div>
                        </div>


                        <notebook>
                            <page name="monday" string="Понедельник">
                                <div class="text-end mb-1">
                                <button name="action_clear_day" type="object" string="Очистить понедельник" 
                                        class="btn-secondary btn-sm" icon="fa-trash"
                                        context="{'day_to_clear': 0}"
                                        title="Очистить все уроки понедельника"/>
                            </div>
                                <field name="time_table_lines_1" nolabel="1" context="{'default_day': '0'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="tuesday" string="Вторник">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить вторник" 
                                        class="btn-secondary btn-sm" icon="fa-trash"
                                        context="{'day_to_clear': 1}"/>
                                </div>
                                <field name="time_table_lines_2" nolabel="1" context="{'default_day': '1'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="wednesday" string="Среда">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить среду" 
                                            class="btn-secondary btn-sm" icon="fa-trash"
                                            context="{'day_to_clear': 2}"/>
                                </div>
                                <field name="time_table_lines_3" nolabel="1" context="{'default_day': '2'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="thursday" string="Четверг">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить четверг" 
                                            class="btn-secondary btn-sm" icon="fa-trash"
                                            context="{'day_to_clear': 3}"/>
                                </div>
                                <field name="time_table_lines_4" nolabel="1" context="{'default_day': '3'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="friday" string="Пятница">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить пятницу" 
                                            class="btn-secondary btn-sm" icon="fa-trash"
                                            context="{'day_to_clear': 4}"/>
                                </div>
                                <field name="time_table_lines_5" nolabel="1" context="{'default_day': '4'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="saturday" string="Суббота">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить субботу" 
                                            class="btn-secondary btn-sm" icon="fa-trash"
                                            context="{'day_to_clear': 5}"/>
                                </div>
                                <field name="time_table_lines_6" nolabel="1" context="{'default_day': '5'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page name="sunday" string="Воскресенье">
                                <div class="text-end mb-1">
                                    <button name="action_clear_day" type="object" string="Очистить воскресенье" 
                                            class="btn-secondary btn-sm" icon="fa-trash"
                                            context="{'day_to_clear': 6}"/>
                                </div>
                                <field name="time_table_lines_7" nolabel="1" context="{'default_day': '6'}">
                                    <list editable="bottom" default_order="timing_id asc">
                                        <field name="day" column_invisible="True"/>
                                        <field name="timing_id" string="Урок" width="100px" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_id" widget="many2one_avatar_user" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="faculty_subject_ids" column_invisible="True"/>
                                        <field name="subject_id" string="Предмет" options="{'no_create': True, 'no_open': True}" domain="[('id', 'in', faculty_subject_ids)]"/>
                                        <field name="classroom_id" string="Кабинет" width="100px" options="{'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button string="Создать" type="object" name="act_gen_time_table" class="btn-primary shadow-sm"/>
                        <button special="cancel" string="Закрыть" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="act_open_generate_time_table_view">
            <field name="name">Создать расписание</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">generate.time.table</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record model="ir.actions.act_window.view" id="act_open_generate_time_table_view_form">
            <field name="act_window_id" ref="act_open_generate_time_table_view"/>
            <field name="sequence" eval="20"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_generate_time_table_form"/>
        </record>

</odoo>
