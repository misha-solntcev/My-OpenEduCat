<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_op_session_tree" model="ir.ui.view">
        <field name="name">op.session.list</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <list string="Sessions" sample="1">
                <field name="start_datetime" />
                <field name="end_datetime" optional="show" />
                <field name="faculty_id" widget="many2one_avatar_user" />
                <field name="subject_id" />
                <field name="course_id" optional="show" />
                <field name="batch_id" optional="hide" />
                <field name="classroom_id" />
                <field name="type" widget="badge" />
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'confirm'" />
            </list>
        </field>
    </record>

    <record id="view_op_session_form" model="ir.ui.view">
        <field name="name">op.session.form</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <header>
                    <button type="object" name="lecture_confirm"
                        invisible="state != 'draft'" string="Confirm"
                        groups="openeducat_timetable.group_op_timetable_user"
                        class="btn-primary" />
                    <button type="object" name="lecture_done"
                        invisible="state != 'confirm'" string="Mark Done"
                        groups="openeducat_timetable.group_op_timetable_user"
                        class="btn-primary" />
                    <button type="object" name="lecture_draft"
                        invisible="state != 'cancel'" string="Reset to Draft"
                        groups="openeducat_timetable.group_op_timetable_user" />
                    <button type="object" name="lecture_cancel"
                        invisible="state in ('draft','cancel')" string="Cancel"
                        groups="openeducat_timetable.group_op_timetable_user"
                        confirm="Are you sure you want to cancel this session?" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done" />
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                    </div>

                    <field name="active" invisible="1" />
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                        invisible="active" />

                    <div class="oe_title">
                        <label for="name" string="Session Title" />
                        <h1>
                            <field name="name" placeholder="e.g. Mathematics Intro" />
                        </h1>
                    </div>

                    <group>
                        <group name="main_details" string="General Information">
                            <field name="faculty_id" widget="many2one_avatar_user"
                                options="{'no_create': True}" />
                            <field name="subject_id" options="{'no_create': True}" />
                            <field name="course_id" options="{'no_create': True}" />
                            <field name="batch_id"
                                context="{'course_id': course_id, 'get_parent_batch': 1}"
                                options="{'no_create': True}" />
                        </group>
                        <group name="scheduling" string="Time &amp; Location">
                            <label for="start_datetime" string="Schedule" />
                            <div class="o_row">
                                <field name="start_datetime" widget="daterange"
                                    options="{'related_end_date': 'end_datetime'}" required="1" />
                                <span class="fa fa-long-arrow-right mx-2" title="Arrow" />
                                <field name="end_datetime" widget="daterange"
                                    options="{'related_start_date': 'start_datetime'}" required="1" />
                            </div>
                            <field name="classroom_id" options="{'no_create_edit': True}" />
                            <field name="type" />
                            <field name="color" widget="color_picker" />
                        </group>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_op_session_calendar" model="ir.ui.view">
        <field name="name">op.session.calendar</field>
        <field name="model">op.session</field>
        <field name="priority" eval="8" />
        <field name="arch" type="xml">
            <calendar string="Sessions" date_start="start_datetime"
                color="course_id" date_stop="end_datetime">
                <field name="faculty_id" />
                <field name="course_id" />
                <field name="batch_id" />
                <field name="start_datetime" />
                <field name="end_datetime" />
                <field name="subject_id" />
                <field name="type" />
            </calendar>
        </field>
    </record>

    <record model="ir.ui.view" id="view_session_kanban">
        <field name="name">session.kanban</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="days" class="o_kanban_small_column" sample="1"
                quick_create="false" default_order="start_datetime asc">                
                <field name="color" />
                <field name="state" />
                <field name="days" />
                <field name="start_datetime" />
                <templates>
                    <t t-name="card">
                        <div
                            t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click d-flex flex-column shadow-sm p-2">

                            <div class="o_kanban_record_top mb-1">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title fs-6 text-primary">
                                        <field name="subject_id" />
                                    </strong>
                                    <div class="oe_kanban_top_right">
                                        <field name="faculty_id" widget="many2one_avatar_user" />
                                    </div>
                                

                            <div class="o_kanban_record_body small mb-2">
                                <div class="d-flex align-items-center text-muted">
                                    <span class="fa fa-calendar me-1" title="Дата занятия" />
                                    <span class="me-3 fw-bold text-dark">
                                        <t
                                            t-out="record.start_datetime.value ? record.start_datetime.value.substring(0, 10) : ''" />
                                    </span>

                                    <span class="fa fa-clock-o me-1" title="Время занятия" />
                                    <field name="timing" class="me-3 fw-bold" />

                                    <span class="fa fa-users me-1" title="Класс" />
                                    <field name="batch_id" />
                                </div>
                            </div>

                            <div
                                class="o_kanban_record_bottom mt-auto d-flex justify-content-between align-items-center">
                                <div class="oe_kanban_bottom_left">
                                    <field name="type" widget="badge"
                                        decoration-info="type == 'lecture'" />
                                </div>

                                </div>
                                <field name="state" widget="label_selection"
                                    options="{'classes': {'draft': 'default', 'confirm': 'success', 'done': 'primary', 'cancel': 'danger'}}" />
                            </div>
                                
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_op_session_pivot" model="ir.ui.view">
        <field name="name">op.session.pivot</field>
        <field name="model">op.session</field>
        <field name="priority" eval="8" />
        <field name="arch" type="xml">
            <pivot string="Session Analysis">
                <field name="name" />
                <field name="faculty_id" type="col" />
                <field name="course_id" />
                <field name="batch_id" />
                <field name="subject_id" />
                <field name="classroom_id" />
                <field name="start_datetime" type="row" />
                <field name="end_datetime" />
                <field name="type" />
            </pivot>
        </field>
    </record>

    <record id="view_op_session_search" model="ir.ui.view">
        <field name="name">op.session.search</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <search string="Поиск расписания">
                <field name="faculty_id" string="Учитель" />
                <field name="subject_id" string="Предмет" />
                <field name="batch_id" string="Класс" />

                <separator />

                <filter string="Текущая неделя" name="this_week"
                    domain="[
                    ('start_datetime', '&gt;=', (context_today() + relativedelta(weeks=-1, days=1, weekday=0)).strftime('%Y-%m-%d')),
                    ('start_datetime', '&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d'))]" />

                <filter string="Сегодня" name="today"
                    domain="[
                        ('start_datetime', '&gt;=', context_today().strftime('%Y-%m-%d')), 
                        ('start_datetime', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]" />

                <separator />

                <filter string="Мои уроки" name="my_sessions"
                    domain="[('faculty_id.user_id', '=', uid)]" />

                <separator />

                <filter string="Ожидают" name="confirmed" domain="[('state', '=', 'confirm')]" />
                <filter string="Черновики" name="drafts" domain="[('state', '=', 'draft')]" />

                <separator />

                <group expand="0" string="Группировать по...">
                    <filter string="📅 По дням" name="group_day" context="{'group_by': 'days'}" />
                    <filter string="👨‍🏫 По учителю" name="group_faculty"
                        context="{'group_by': 'faculty_id'}" />
                    <filter string="📚 По предмету" name="group_subject"
                        context="{'group_by': 'subject_id'}" />
                    <filter string="🏫 По классу" name="group_batch"
                        context="{'group_by': 'batch_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_session_view">
        <field name="name">Расписание</field>
        <field name="res_model">op.session</field>
        <field name="view_mode">kanban,list,calendar,pivot,form</field>
        <field name="search_view_id" ref="view_op_session_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                На рабочую неделю уроков не запланировано.
            </p>
        </field>
        <field name="context">{
            'search_default_this_week': 1,
            'search_default_group_day': 1
            }</field>
    </record>

</odoo>