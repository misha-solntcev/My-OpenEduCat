<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_op_session_tree" model="ir.ui.view">
        <field name="name">op.session.list</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <list string="Sessions" default_order="start_datetime asc, batch_id, id" sample="1"
                decoration-muted="state == 'draft'"
                decoration-info="state == 'confirm'"
                decoration-primary="state == 'start'"
                decoration-success="state == 'done'"
                decoration-danger="state == 'cancel'">
                <field name="faculty_id" widget="many2one_avatar_user" optional="show"/>
                <field name="subject_id" optional="show"/>
                <field name="start_datetime" optional="show"
                    options="{'related_start_date': 'start_datetime', 
                    'show_seconds': False}"/>
                <field name="end_datetime" optional="show"
                    options="{'related_start_date': 'end_datetime', 
                    'show_seconds': False}" />                
                <field name="course_id" optional="show" />
                <field name="batch_id" optional="hide" />
                <field name="classroom_id" />
                <field name="state" widget="badge"
                    decoration-muted="state == 'draft'"
                    decoration-info="state == 'confirm'"
                    decoration-primary="state == 'start'"
                    decoration-success="state == 'done'"
                    decoration-danger="state == 'cancel'" 
                    optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_op_session_form" model="ir.ui.view">
        <field name="name">op.session.form</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <form string="Session">
                <header>
                    <!-- 1. Из Черновика в Утвержден (Завуч) -->
                    <button name="lecture_confirm" type="object" string="Утвердить"
                        invisible="state != 'draft'" class="btn-primary" icon="fa-check"
                        groups="openeducat_timetable.group_op_timetable_user" />
                    <!-- 2. Из Утвержден в Идет урок (Учитель/Завуч) -->
                    <button name="lecture_start" type="object" string="Начать урок"
                        invisible="state != 'confirm'" class="btn-primary" icon="fa-play"
                        groups="openeducat_timetable.group_op_timetable_user" />
                    <!-- 3. Из Идет урок в Проведен (Учитель/Завуч) -->
                    <button name="lecture_done" type="object" string="Завершить"
                        invisible="state != 'start'" class="btn-primary" icon="fa-check-circle"
                        groups="openeducat_timetable.group_op_timetable_user" />
                    <!-- 4. Отмена (доступна, пока урок не завершен) -->
                    <button name="lecture_cancel" type="object" string="Отменить урок"
                        invisible="state not in ('confirm', 'start')" icon="fa-times"
                        groups="openeducat_timetable.group_op_timetable_user"
                        confirm="Вы уверены, что хотите отменить этот урок? Связанный журнал также будет отменен." />
                    <!-- 5. Восстановить (из Отменен в Черновик) -->
                    <button name="lecture_draft" type="object" string="Восстановить"
                        invisible="state != 'cancel'"
                        groups="openeducat_timetable.group_op_timetable_user"
                        icon="fa-undo" />
                    <button name="lecture_edit" type="object" string="Редактировать"
                        invisible="state != 'done'" icon="fa-edit"
                        groups="openeducat_timetable.group_op_timetable_user" />

                    <!-- Статус-бар -->
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirm,start,done" />
                </header>
                <sheet>

                    <div name="button_box" class="oe_button_box">
                    </div>

                    <field name="active" invisible="1" />
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                        invisible="active" />

                    <div class="oe_title">
                        <label for="name" string="Session Title" />
                        <h1>
                            <field name="name" placeholder="e.g. Mathematics Intro" />
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="faculty_id" widget="many2one_avatar_user"
                                options="{'no_create': True}" />
                            <field name="subject_id" options="{'no_create': True}" />
                            <field name="course_id" options="{'no_create': True}" />
                            <field name="batch_id"
                                context="{'course_id': course_id, 'get_parent_batch': 1}"
                                options="{'no_create': True}" />
                        </group>
                        <group>
                            <label for="start_datetime" string="Schedule" />
                            <div class="o_row">
                                <field name="start_datetime" widget="daterange"
                                    options="{'related_start_date': 'start_datetime',
                                    'show_seconds': False, 'rounding': 10}"
                                    required="1" />
                                <span class="fa fa-long-arrow-right mx-2" title="Arrow" />
                                <field name="end_datetime" widget="daterange"
                                options="{
                                    'related_end_date': 'end_datetime', 
                                    'show_seconds': False, 'rounding': 10}"
                                    required="1" />                                    
                            </div>
                            <field name="classroom_id" options="{'no_create_edit': True}" />

                            <field name="color" widget="color_picker" />
                        </group>
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_op_session_calendar" model="ir.ui.view">
        <field name="name">op.session.calendar</field>
        <field name="model">op.session</field>
        <field name="priority" eval="8" />
        <field name="arch" type="xml">
            <calendar string="Sessions" date_start="start_datetime"
                color="course_id" date_stop="end_datetime">
                <field name="faculty_id" />
                <field name="course_id" />
                <field name="batch_id" />
                <field name="start_datetime" />
                <field name="end_datetime" />
                <field name="subject_id" />

            </calendar>
        </field>
    </record>

    <record model="ir.ui.view" id="view_session_kanban">
        <field name="name">session.kanban</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="days_id" class="o_kanban_small_column" sample="1"
                quick_create="false" default_order="start_datetime asc, batch_id, id">
                <field name="color" />
                <field name="state" />
                <field name="days_id" />
                <field name="start_datetime" />
                <field name="subject_id" />
                <field name="faculty_id" />
                <field name="batch_id" />
                <templates>
                    <t t-name="card">
                        <div
                            t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click shadow-sm p-2"
                            style="min-height: unset;">

                            <div class="d-flex align-items-start justify-content-between mb-1">
                                <div class="d-flex flex-column text-truncate">
                                    <strong class="o_kanban_record_title text-primary text-truncate"
                                        style="font-size: 0.9rem; line-height: 1.1;">
                                        <field name="subject_id" />
                                    </strong>
                                    <div class="text-muted small d-flex align-items-center mt-1">
                                        <span class="fa fa-calendar me-1"
                                            style="font-size: 0.75rem; opacity: 0.8;" />
                                        <span class="fw-bold text-dark me-2">
                                            <t t-if="record.start_datetime.raw_value">
                                                <t
                                                    t-out="record.start_datetime.value.split(' ')[0].split('-').reverse().join('.')" />
                                            </t>
                                        </span>

                                        <span class="mx-1 text-silver">|</span>

                                        <span class="fa fa-clock-o me-1 ms-1"
                                            style="font-size: 0.75rem; opacity: 0.8;" />
                                        <field name="timing" class="fw-bold text-dark" />
                                    </div>
                                </div>
                                <div class="ms-2">
                                    <field name="faculty_id" widget="many2one_avatar_user" />
                                </div>
                            </div>
                            <div
                                class="o_kanban_record_bottom border-top pt-1 mt-2 d-flex justify-content-between align-items-center">
                                <div class="small text-muted d-flex align-items-center">
                                    <span class="fa fa-users me-1" title="Students" />
                                    <field name="batch_id" class="fw-bold" />
                                </div>
                                <div>
                                    <field name="state" widget="badge"
                                        decoration-muted="state == 'draft'"
                                        decoration-info="state == 'confirm'"
                                        decoration-primary="state == 'start'"
                                        decoration-success="state == 'done'"
                                        decoration-danger="state == 'cancel'" />
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_op_session_pivot" model="ir.ui.view">
        <field name="name">op.session.pivot</field>
        <field name="model">op.session</field>
        <field name="priority" eval="8" />
        <field name="arch" type="xml">
            <pivot string="Session Analysis">
                <field name="name" />
                <field name="faculty_id" type="col" />
                <field name="course_id" />
                <field name="batch_id" />
                <field name="subject_id" />
                <field name="classroom_id" />
                <field name="start_datetime" type="row" />
                <field name="end_datetime" />

            </pivot>
        </field>
    </record>

    <record id="view_op_session_search" model="ir.ui.view">
        <field name="name">op.session.search</field>
        <field name="model">op.session</field>
        <field name="arch" type="xml">
            <search string="Поиск расписания">
                <field name="faculty_id" string="Учитель" />
                <field name="subject_id" string="Предмет" />
                <field name="batch_id" string="Класс" />
                <field name="timetable_date" string="Дата урока" />

                <separator />

                <!-- Группа 1: ПЕРИОДЫ -->
                <filter string="🗓️ Предыдущая неделя" name="previous_week"
                    domain="[
                        ('timetable_date', '&gt;=', (context_today() + relativedelta(weeks=-1, weekday=0)).strftime('%Y-%m-%d')),
                        ('timetable_date', '&lt;=', (context_today() + relativedelta(weeks=-1, weekday=6)).strftime('%Y-%m-%d'))]" />

                <filter string="📅 Текущая неделя" name="this_week"
                    domain="[
                        ('timetable_date', '&gt;=', (context_today() + relativedelta(weeks=0, weekday=0)).strftime('%Y-%m-%d')),
                        ('timetable_date', '&lt;=', (context_today() + relativedelta(weeks=0, weekday=6)).strftime('%Y-%m-%d'))]" />
                
                <filter string="📆 Следующая неделя" name="next_week" 
                    domain="[
                        ('timetable_date', '&gt;=', (context_today() + relativedelta(weeks=1, weekday=0)).strftime('%Y-%m-%d')),
                        ('timetable_date', '&lt;=', (context_today() + relativedelta(weeks=1, weekday=6)).strftime('%Y-%m-%d'))]" />

                <filter string="📍Сегодня" name="today"
                    domain="[('timetable_date', '=', context_today().strftime('%Y-%m-%d'))]" />

                <separator />

                <filter string="Мои уроки" name="my_sessions"
                    domain="[('faculty_id.user_id', '=', uid)]" />

                <separator />

                <filter string="⚪ Черновик" name="draft" domain="[('state', '=', 'draft')]" />
                <filter string="🔵 Утвержден" name="confirm" domain="[('state', '=', 'confirm')]" />
                <filter string="🟣 Идет урок" name="start" domain="[('state', '=', 'start')]" />
                <filter string="🟢 Проведен" name="done" domain="[('state', '=', 'done')]" />
                <filter string="🔴 Отменен" name="cancel" domain="[('state', '=', 'cancel')]" />

                <separator />

                <group expand="0" string="Группировать по...">
                    <filter string="📅 По дням недели" name="group_day" context="{'group_by': 'days_id'}" />
                    <filter string="👨‍🏫 По учителю" name="group_faculty"
                        context="{'group_by': 'faculty_id'}" />
                    <filter string="📚 По предмету" name="group_subject"
                        context="{'group_by': 'subject_id'}" />
                    <filter string="🏫 По классу" name="group_batch"
                        context="{'group_by': 'batch_id'}" />
                    <filter string="🗓️ Дата урока" name="group_date" context="{'group_by': 'timetable_date'}" />            
                </group>
                <searchpanel>
                    <!-- Фильтр по классам -->
                    <field name="batch_id"
                        string="Класс"
                        select="one"
                        icon="fa-users"
                        enable_counters="1" />

                    <!-- Фильтр по учителям -->
                    <field name="faculty_id"
                        expand="0"
                        string="Учителя"
                        select="one"
                        icon="fa-graduation-cap"
                        enable_counters="1" />
                </searchpanel>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_op_session_view">
        <field name="name">Расписание</field>
        <field name="res_model">op.session</field>
        <field name="view_mode">calendar,kanban,list,pivot,form</field>
        <field name="search_view_id" ref="view_op_session_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                На выбранную неделю уроков нет.
            </p>
        </field>
        <field name="context">{
            'search_default_this_week': 1,
            'search_default_group_day': 1
            }</field>
    </record>

</odoo>