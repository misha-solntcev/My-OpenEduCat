<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_view_form_timetable" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.timetable</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="openeducat_core.res_config_settings_view_form_core"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='timetable_constraints']" position="after">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="prevent_faculty_overlap"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="prevent_faculty_overlap" string="Запретить совмещение учителя"/>
                        <div class="text-muted">
                            Запретить назначать одного учителя на несколько уроков одновременно.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="prevent_batch_overlap"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="prevent_batch_overlap" string="Запретить совмещение класса"/>
                        <div class="text-muted">
                            Запретить назначать один класс на несколько уроков одновременно.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="prevent_classroom_overlap"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="prevent_classroom_overlap" string="Запретить совмещение кабинета"/>
                        <div class="text-muted">
                            Запретить занимать один кабинет разными уроками одновременно.
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
