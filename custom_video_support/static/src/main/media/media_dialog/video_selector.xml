<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="html_editor.VideoSelector" t-inherit-mode="extension">
        <!-- Находим контейнер с подсказкой внутри формы -->
        <xpath expr="//div[contains(@class, 'o_video_dialog_form')]//div[contains(@class, 'text-start')]" position="replace">
            <div class="text-start">
                <small class="text-muted">
                    Принимает <b><i>Youtube</i></b>, <b><i>Vimeo</i></b>, <b><i>Dailymotion</i></b>, <b><i>Instagram</i></b>, <b><i>VK</i></b> и <b><i>Rutube</i></b> видео
                </small>
            </div>
        </xpath>
    </t>
</templates>
