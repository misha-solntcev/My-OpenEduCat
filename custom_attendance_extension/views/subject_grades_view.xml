<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Расширение списка оценок по предметам для отображения таблицы с темами уроков -->
    <record id="view_op_subject_grades_tree_custom" model="ir.ui.view">
        <field name="name">op.subject.grades.tree.custom</field>
        <field name="model">op.subject.grades</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_subject_grades_tree"/>
        <field name="arch" type="xml">
            <field name="average_mark" position="after">
                <field name="date_mark_table" widget="html" string="Таблица оценок и посещений"/>
            </field>
        </field>
    </record>
    
    <!-- Расширение формы оценок по предметам для отображения таблицы с темами уроков -->
    <record id="view_op_subject_grades_form_custom" model="ir.ui.view">
        <field name="name">op.subject.grades.form.custom</field>
        <field name="model">op.subject.grades</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_subject_grades_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Таблица оценок и посещений">
                    <field name="date_mark_table" widget="html"/>
                </page>
            </notebook>
        </field>
    </record>
</odoo>