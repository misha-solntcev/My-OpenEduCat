<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_op_subject_grades_form_custom" model="ir.ui.view">
        <field name="name">op.subject.grades.form.custom</field>
        <field name="model">op.subject.grades</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_subject_grades_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='marks']" position="after">
                <field name="lesson_topics"/>
            </xpath>
        </field>
    </record>
    
    <record id="view_op_subject_grades_search_custom" model="ir.ui.view">
        <field name="name">op.subject.grades.search.custom</field>
        <field name="model">op.subject.grades</field>
        <field name="inherit_id" ref="openeducat_attendance.view_op_subject_grades_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="lesson_topics"/>
            </xpath>
        </field>
    </record>
    
    <!-- Удаляем запись с канбан-представлением, чтобы не отображать темы уроков в канбане -->
</odoo>